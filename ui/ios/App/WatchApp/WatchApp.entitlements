<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Group shared with the iPhone main app + extensions so the
	     watch reads the same widget state. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.heron.app</string>
	</array>
</dict>
</plist>
