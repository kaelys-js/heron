# heron iOS — Fastlane lanes.
#
# `bundle exec fastlane beta` builds the app, signs it, and uploads to
# TestFlight for internal-tester distribution. No App Store submission
# (deliberately — the app is for personal use).
#
# Authentication uses App Store Connect API keys (the modern, 2FA-safe
# approach). Legacy Apple-ID + app-specific-password is NOT used.
#
# Required secrets (env vars in CI, .env locally):
#   APPLE_TEAM_ID                       — found in developer.apple.com Membership
#   APP_STORE_CONNECT_API_KEY_ID        — 10-char key ID from App Store Connect → Users → Keys
#   APP_STORE_CONNECT_API_ISSUER_ID     — UUID issuer ID from the same page
#   APP_STORE_CONNECT_API_KEY           — full .p8 file contents (base64 or raw)
#
# Optional (only when using `match` for cert distribution):
#   MATCH_GIT_URL                       — private repo holding signed certs / profiles
#   MATCH_PASSWORD                      — encryption password for the match repo
#
# For first-run setup, see SETUP-FASTLANE.md.

default_platform(:ios)

APP_IDENTIFIER = "com.resistjs.heron"
# Every app-store-signed bundle id (main app + embedded extensions + watch).
# match provisions one profile per id, named "match AppStore <id>".
ALL_APP_IDENTIFIERS = [
  APP_IDENTIFIER,
  "#{APP_IDENTIFIER}.watchkitapp",
  "#{APP_IDENTIFIER}.widget",
  "#{APP_IDENTIFIER}.liveactivity",
  "#{APP_IDENTIFIER}.share",
].freeze
# Internal TestFlight group that auto-receives every build. The release
# adds the account holder (ENV APPLE_ID) so each build lands on-device with
# no manual step.
INTERNAL_GROUP_NAME = "Heron Internal"
# Capacitor 8+ uses SPM (Swift Package Manager) -- no Podfile, no
# auto-generated `App.xcworkspace` at the top level. Build straight off
# `App.xcodeproj`; SPM packages are wired up via project references.
# (The project DOES have an internal `project.xcworkspace` for xcodebuild
# but that's the per-project Xcode-managed one, not the CocoaPods
# integration workspace fastlane expects when you pass `workspace:`.)
PROJECT = "App.xcodeproj"
# Test schemes:
#  - iOS schemes run on the newest installed iOS simulator (resolved at
#    runtime by newest_sim_destination -- latest on the macos-latest image).
#    AppTests is the host-app test bundle; the other three are LOGIC
#    test bundles that compile the extension's production .swift files
#    into the test bundle directly (extensions can't be TEST_HOST).
#  - WatchTests runs on the newest installed watchOS simulator (same
#    runtime-resolution helper).
#
# Order matters: AppTests runs LAST so its xccov data is the most-
# recent entry in Xcode's DerivedData/Logs/Test/ -- xcov 1.9.0 reads
# the latest xccov from DerivedData without a path override, so a
# later AppLiveActivityTests run would clobber AppTests' coverage
# and xcov would gate on the wrong xcresult.
IOS_TEST_SCHEMES = [
  "WidgetTests",
  "AppLiveActivityTests",
  "AppShareExtensionTests",
  # XCUITest end-to-end cases (ColdLaunch / DeepLink / Login / Sidebar /
  # NotificationsBell / ShareExtension / Screenshot). The AppUITests
  # target is a ui-testing bundle (productType bundle.ui-testing,
  # TEST_TARGET_NAME=App, no TEST_HOST) so XCTRunner drives the app with
  # no config conflict. Listed BEFORE AppTests so AppTests still runs
  # last (its xccov stays the most-recent App.app entry slather reads).
  "AppUITests",
  "AppTests",
].freeze
WATCH_TEST_SCHEME = "WatchTests"
SCHEME = "App"
# Separate scheme for test_ci: AppTests bundle (which has App as its
# test host, so xcodebuild builds the host app as an implicit
# dependency). The handwritten App.xcscheme triggered a persistent
# "Scheme App is not currently configured for the build action" error
# under Xcode 16 even after Foundation-SDK hardcodes were stripped --
# the App scheme metadata Xcode generates for a freshly-imported
# project diverges from what scan expects. AppTests.xcscheme came from
# the original Xcode-managed scheme generation + has no such bug.
TEST_SCHEME = "AppTests"

# Per-scheme coverage config. Each scheme produces ONE cobertura.xml at
# `fastlane/coverage/<scheme>/cobertura.xml` via
# scripts/native/xccov-to-cobertura.mjs (which reads `xcrun xccov`
# directly -- slather 2.8.5 couldn't find the per-line execution data
# when run_tests writes the result bundle to a custom output_directory,
# so it emitted 0% for every target; see the script header).
#
# The value is the source-path substring the report keeps -- the
# converter restricts each scheme's coverage to that one source dir and
# drops Brand.swift / ErrorReporter.swift / *Smoke.swift. AppTests +
# AppUITests both measure the App.app source (AppUITests via the
# XCUITest's real WebView load); the logic bundles (Widget /
# LiveActivity / ShareExtension) measure their extension source compiled
# into the test bundle.
COVERAGE_TARGETS = {
  "AppTests"               => "/App/App/",
  "AppUITests"             => "/App/App/",
  "WidgetTests"            => "/Extensions/AppWidget/",
  "AppLiveActivityTests"   => "/Extensions/AppLiveActivity/",
  "AppShareExtensionTests" => "/Extensions/AppShareExtension/",
  "WatchTests"             => "/WatchApp/",
}.freeze

# Fastlane defaults that affect every lane.
ENV["FASTLANE_OPT_OUT_USAGE"] = "1"           # don't phone home
ENV["FASTLANE_HIDE_CHANGELOG"] = "1"
ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"

platform :ios do
  before_all do
    setup_ci if is_ci
    # Pin Xcode for CI consistency. Uncomment when the build runs on a
    # macOS image that ships multiple Xcode versions.
    # xcode_select("/Applications/Xcode_26.app") if is_ci
  end

  desc "Construct the App Store Connect API key (used by every lane below)"
  private_lane :asc_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true,  # secret is stored base64 (see native-release.yml / setup.mjs)
      duration: 1200,    # seconds; ASC max is 1200
      in_house: false
    )
  end

  desc "Resolve signing: use match if a cert-repo is configured, else local keychain"
  private_lane :sign do |options|
    api_key = options[:api_key]
    if ENV["MATCH_GIT_URL"]
      match(
        type: "appstore",
        app_identifier: ALL_APP_IDENTIFIERS,
        git_url: ENV["MATCH_GIT_URL"],
        api_key: api_key,
        readonly: is_ci,
        force_for_new_devices: false
      )
    end
  end

  desc "One-time: register App IDs + push signing certs + profiles to match repo"
  # Run locally by `pnpm setup:native` after it provisions the certs repo
  # + deploy key. Registers every bundle id, then writes the Apple
  # Distribution cert + one "match AppStore <id>" profile per bundle id into
  # the encrypted match repo. CI never runs this; CI signs read-only via the
  # `sign` lane (readonly: is_ci).
  lane :match_bootstrap do
    api_key = asc_key
    register_app_ids
    match(
      type: "appstore",
      app_identifier: ALL_APP_IDENTIFIERS,
      git_url: ENV["MATCH_GIT_URL"],
      api_key: api_key,
      readonly: false,
      # Force regeneration so profiles pick up capability changes made on the
      # Dev Portal (App Groups association, background-tasks, live-activities)
      # that the App Store Connect API can't set.
      force: true,
      force_for_new_devices: false
    )
  end

  desc "Ensure every bundle id exists on the Dev Portal with App Groups enabled"
  # match creates profiles but never App IDs, so on a fresh account the
  # extension ids (watch / widget / liveactivity / share) must be registered
  # first or match fails with "couldn't find bundle id". App Groups is the
  # one capability every extension entitlement needs; Live Activities needs
  # no portal capability. Idempotent -- skips ids + capabilities that exist.
  private_lane :register_app_ids do
    require "spaceship"
    require "base64"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY"])
    )
    existing = Spaceship::ConnectAPI::BundleId.all
    ALL_APP_IDENTIFIERS.each do |bid|
      app = existing.find { |b| b.identifier == bid }
      unless app
        app = Spaceship::ConnectAPI::BundleId.create(
          name: "Heron #{bid.split('.').last.capitalize}",
          identifier: bid,
          platform: "IOS"
        )
        UI.success("registered App ID #{bid}")
      end
      unless app.get_capabilities.map { |c| c.capability_type.to_s }.include?("APP_GROUPS")
        app.create_capability("APP_GROUPS")
        UI.success("enabled App Groups on #{bid}")
      end
    end
  end

  desc "Build + sign + upload to TestFlight"
  # WatchApp bundling: the iOS `App` scheme has an "Embed Watch Content"
  # build phase that copies WatchApp.app into App.app/Watch/. Verified
  # via App.xcodeproj/project.pbxproj entry `WatchApp.app in Embed
  # Watch Content`. So build_app below produces an .ipa that includes
  # both the iOS app + the watchOS app -- TestFlight then installs the
  # watch app on any paired Apple Watch automatically. No separate
  # gym invocation for the WatchApp scheme is needed.
  lane :beta do
    # Bump build number to current epoch — deterministic and always larger
    # than any prior build. Override with EXACT_BUILD_NUMBER when the
    # caller wants a stable suffix (testflight-keepalive uses this).
    new_build = ENV["EXACT_BUILD_NUMBER"] || Time.now.to_i.to_s
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: new_build
    )

    api_key = asc_key
    sign(api_key: api_key)

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      # Manual signing with the match distribution profiles (automatic signing
      # demands development certs/profiles a distribution-only CI runner does
      # not have). xcargs (team id, marketing version, skip flags) are built
      # by release_xcargs so beta + app_store stay in lockstep.
      xcargs: release_xcargs,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: ALL_APP_IDENTIFIERS.to_h { |id| [id, "match AppStore #{id}"] }
      },
      configuration: "Release",
      clean: true,
      output_directory: "fastlane/builds",
      output_name: "heron-#{Time.now.utc.strftime('%Y%m%d%H%M%S')}.ipa",
      include_symbols: true,
      include_bitcode: false   # Apple deprecated bitcode in Xcode 14
    )

    # "What to Test" notes: CHANGELOG.md for this version (Release Please
    # source), falling back to the last commit message. See testflight_changelog.
    notes = testflight_changelog

    upload_to_testflight(
      api_key: api_key,
      # Must be false to set the changelog: fastlane/pilot SKIPS the changelog
      # ("What to Test") entirely when skip_waiting is true. Costs a processing
      # wait (a few minutes) but the build then shows release notes in TestFlight.
      skip_waiting_for_build_processing: false,
      changelog: notes,
      distribute_external: false,           # internal testers only
      reject_build_waiting_for_review: false
    )

    # Reliability net. A read-only ASC audit found the changelog param alone
    # left EVERY uploaded build with no betaBuildLocalizations (whatsNew
    # empty) — so internal testers saw no "What to Test". Explicitly create /
    # update the en-US whatsNew on the build we just shipped so the notes
    # reliably land. Best-effort + loud (mirrors ensure_internal_delivery).
    set_whats_to_test(build_number: new_build, notes: notes)

    ensure_internal_delivery
    set_age_rating
  end

  desc "Zero-touch TestFlight: an internal group that auto-receives every"
  # build, with the account holder as a member, so each release lands on
  # their device with no manual step. Best-effort -- a hiccup here must not
  # fail an otherwise-good build + upload. asc_key already set the Spaceship
  # token, so ConnectAPI calls are authed.
  private_lane :ensure_internal_delivery do
    begin
      app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == APP_IDENTIFIER }
      raise "App Store Connect app not found for #{APP_IDENTIFIER}" unless app
      group = app.get_beta_groups.find { |g| g.name == INTERNAL_GROUP_NAME }
      unless group
        # spaceship's create_beta_group always sends publicLinkLimitEnabled,
        # which ASC rejects for internal groups. POST the betaGroup directly
        # with only the internal-valid attributes, then re-fetch it.
        Spaceship::ConnectAPI.client.test_flight_request_client.post("v1/betaGroups", {
          data: {
            type: "betaGroups",
            attributes: {
              name: INTERNAL_GROUP_NAME,
              isInternalGroup: true,
              hasAccessToAllBuilds: true
            },
            relationships: { app: { data: { id: app.id, type: "apps" } } }
          }
        })
        group = app.get_beta_groups.find { |g| g.name == INTERNAL_GROUP_NAME }
        raise "internal group missing after create" unless group
      end
      owner = ENV["APPLE_ID"].to_s
      if owner.empty?
        # Loud, not silent: a missing APPLE_ID is exactly why the maintainer
        # would never receive builds. Surface it as a CI warning annotation.
        msg = "APPLE_ID not set -- nobody added to '#{INTERNAL_GROUP_NAME}'. Set the APPLE_ID secret so builds reach you."
        UI.important(msg)
        puts "::warning title=TestFlight invite::#{msg}" if is_ci
      else
        members = (group.get_beta_testers.map(&:email) rescue [])
        if members.include?(owner)
          UI.message("internal delivery: '#{INTERNAL_GROUP_NAME}' already covers #{owner}")
        else
          client = Spaceship::ConnectAPI.client.test_flight_request_client
          # spaceship's post_bulk_beta_tester_assignments targets
          # v1/bulkBetaTesterAssignments, which ASC rejects ("resource does
          # not exist"). Use the stable endpoints instead: attach an already-
          # existing tester via the group's relationships endpoint, else
          # create the tester with the group relationship in one POST.
          existing = (Spaceship::ConnectAPI::BetaTester.all(filter: { email: owner }).first rescue nil)
          begin
            if existing
              client.post("v1/betaGroups/#{group.id}/relationships/betaTesters", {
                data: [{ type: "betaTesters", id: existing.id }]
              })
            else
              client.post("v1/betaTesters", {
                data: {
                  type: "betaTesters",
                  attributes: { email: owner, firstName: "Heron", lastName: "Maintainer" },
                  relationships: { betaGroups: { data: [{ type: "betaGroups", id: group.id }] } }
                }
              })
            end
            UI.success("internal delivery: added #{owner} to '#{INTERNAL_GROUP_NAME}'")
          rescue StandardError => e
            # Internal groups auto-include App Store Connect users by ASC role.
            # The account holder already receives every build, so ASC refuses an
            # explicit assignment with "Tester(s) cannot be assigned" / "state of
            # another resource". That is the expected steady state once the
            # maintainer is set up -- treat it as already-covered, not a failure.
            # Re-raise anything genuinely unexpected.
            raise unless e.message =~ /cannot be assigned|state of another resource|already exists/i
            UI.message("internal delivery: #{owner} already covered (internal ASC user)")
          end
        end
      end
    rescue => e
      # Best-effort, but never silent: surface the failure as a CI annotation
      # so a broken invite can't masquerade as a clean run again.
      msg = "internal-delivery setup FAILED (build + upload still OK): #{e.message}"
      UI.important(msg)
      puts "::warning title=TestFlight invite::#{msg}" if is_ci
    end
  end

  desc "Reliably set the uploaded build's TestFlight 'What to Test' (en-US)"
  # The upload_to_testflight `changelog:` param has, in practice, left builds
  # with NO betaBuildLocalizations (whatsNew empty) -- confirmed via a
  # read-only ASC audit. This explicitly creates/updates the en-US localization
  # on the build we just uploaded so the notes always appear. Uses the low-level
  # ConnectAPI request client (the high-level models have known POST bugs — same
  # rationale as ensure_internal_delivery). Best-effort + loud.
  private_lane :set_whats_to_test do |options|
    notes = options[:notes].to_s
    build_number = options[:build_number].to_s
    begin
      raise "no notes to set" if notes.strip.empty?
      raise "no build number" if build_number.empty?
      app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == APP_IDENTIFIER }
      raise "App Store Connect app not found for #{APP_IDENTIFIER}" unless app

      # The build we just uploaded carries CFBundleVersion == build_number.
      # Poll until ASC finishes processing it (VALID) so the localization sticks
      # (a non-processed build rejects the betaBuildLocalizations write).
      # Spaceship's Build.all takes app_id: + build_number: keywords (the
      # CFBundleVersion), NOT a `filter:` hash. The old `filter:` form raised
      # ArgumentError: unknown keyword :filter on the FIRST call -- caught by
      # the rescue below, so the lane silently no-op'd and EVERY build shipped
      # with no betaBuildLocalizations (empty "What's New"). (`version:` is the
      # marketing version; the uploaded build is keyed by CFBundleVersion.)
      build = nil
      30.times do
        build = Spaceship::ConnectAPI::Build.all(
          app_id: app.id, build_number: build_number, limit: 1
        ).first
        break if build && build.processing_state == "VALID"
        sleep(20)
      end
      raise "build #{build_number} not found / not VALID in time" unless build && build.processing_state == "VALID"

      client = Spaceship::ConnectAPI.client.test_flight_request_client
      existing = (build.get_beta_build_localizations rescue []).find { |l| l.locale == "en-US" }
      if existing
        client.patch("v1/betaBuildLocalizations/#{existing.id}", {
          data: {
            type: "betaBuildLocalizations",
            id: existing.id,
            attributes: { whatsNew: notes }
          }
        })
      else
        client.post("v1/betaBuildLocalizations", {
          data: {
            type: "betaBuildLocalizations",
            attributes: { locale: "en-US", whatsNew: notes },
            relationships: { build: { data: { type: "builds", id: build.id } } }
          }
        })
      end
      UI.success("What to Test set on build #{build_number}")
    rescue => e
      msg = "set_whats_to_test FAILED (build + upload still OK): #{e.message}"
      UI.important(msg)
      puts "::warning title=What to Test::#{msg}" if is_ci
    end
  end

  desc "Set the App Store age rating (ASC API). Privacy label is one-time manual."
  # Age rating derives from brand contentRating and IS settable via the ASC API
  # key. The App Privacy nutrition LABEL is NOT exposed on the official ASC API
  # key (Apple limitation -- fastlane's upload_app_privacy_details_to_app_store
  # docs: "not available on the official App Store Connect API"), so it's a
  # one-time manual entry in ASC; this lane logs the exact brand-derived entries
  # to make. Best-effort + loud (mirrors ensure_internal_delivery): a hiccup
  # must not fail an otherwise-good build.
  private_lane :set_age_rating do
    begin
      app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == APP_IDENTIFIER }
      raise "App Store Connect app not found for #{APP_IDENTIFIER}" unless app
      apply_age_rating(app)
      log_manual_privacy_label
      UI.success("age rating applied for #{APP_IDENTIFIER}")
    rescue => e
      msg = "age-rating setup FAILED (build + upload still OK): #{e.message}"
      UI.important(msg)
      puts "::warning title=Age rating::#{msg}" if is_ci
    end
  end

  # "4+": every content descriptor NONE and every boolean false, no override
  # -- ASC then computes 4+. Only 4+ is mapped (Heron has no objectionable
  # content); a higher brand rating needs its own descriptors, so fail loud
  # rather than mis-declare. Field set per spaceship 2.234 (2025 overhaul).
  def apply_age_rating(app)
    rating = brand_app_store.fetch("contentRating", "4+").to_s
    UI.user_error!("age rating '#{rating}' not mapped (only 4+ implemented)") unless rating == "4+"
    app_info = app.fetch_edit_app_info
    raise "no editable app info (need PREPARE_FOR_SUBMISSION to set age rating)" unless app_info
    decl = app_info.fetch_age_rating_declaration
    raise "app info has no age rating declaration" unless decl
    ratings = %w[
      alcoholTobaccoOrDrugUseOrReferences contests gamblingSimulated gunsOrOtherWeapons
      horrorOrFearThemes matureOrSuggestiveThemes medicalOrTreatmentInformation
      profanityOrCrudeHumor sexualContentGraphicAndNudity sexualContentOrNudity
      violenceCartoonOrFantasy violenceRealisticProlongedGraphicOrSadistic violenceRealistic
    ]
    booleans = %w[
      advertising ageAssurance gambling healthOrWellnessTopics lootBox messagingAndChat
      parentalControls unrestrictedWebAccess userGeneratedContent
    ]
    attributes = {}
    ratings.each { |k| attributes[k] = "NONE" }
    booleans.each { |k| attributes[k] = false }
    attributes["ageRatingOverrideV2"] = "NONE"
    Spaceship::ConnectAPI.patch_age_rating_declaration(age_rating_declaration_id: decl.id, attributes: attributes)
    UI.message("age rating: 4+ (all descriptors NONE/false)")
  end

  # The App Privacy nutrition label is NOT reachable via the ASC API key, so it
  # is a one-time manual entry in App Store Connect. Log the exact brand-derived
  # declaration (kept in sync with PrivacyInfo.xcprivacy) so the manual entry is
  # unambiguous. Run via `fastlane ios store_config` to print it on demand.
  def log_manual_privacy_label
    types = brand_app_store.dig("privacy", "dataTypes") || []
    return if types.empty?
    lines = types.map do |t|
      linked = t["protection"] == "DATA_LINKED_TO_YOU" ? "Linked to user" : "Not linked to user"
      "#{t['category']} -> #{linked}; purposes #{Array(t['purposes']).join(' + ')}; NOT used for tracking"
    end
    UI.message("App Privacy (set ONCE in ASC -> App Privacy, then matches PrivacyInfo.xcprivacy):")
    lines.each { |l| UI.message("  - #{l}") }
  end

  # branding/brand.json -> store.appStore, memoized. Path walks up out of
  # fastlane -> App -> ios -> ui -> repo root.
  def brand_app_store
    require "json"
    @brand_app_store ||=
      JSON.parse(File.read(File.expand_path("../../../../branding/brand.json", __dir__))).dig("store", "appStore") || {}
  end

  desc "Fast app-level App Store config (privacy label + age rating), no build/upload"
  # Iterates the ASC-config lanes in ~90s instead of a full ~10min build +
  # TestFlight upload (which is what dominates native-release time -- see the
  # caching audit). Dispatched by .github/workflows/store-config.yml. asc_key
  # sets the Spaceship token the ConnectAPI helpers rely on.
  lane :store_config do
    asc_key
    set_age_rating
  end

  desc "Upload App Store metadata + screenshots without rebuilding the IPA"
  lane :upload_metadata do
    # `deliver` reads fastlane/metadata/* (name, subtitle, description,
    # keywords, marketing/privacy/support URLs, review notes, category)
    # and fastlane/screenshots/* (per-locale, per-device-class). Skipping
    # ipa + binary upload because this lane is for content-only changes
    # — the next `beta` lane will pick up a fresh build with the same
    # metadata attached.
    api_key = asc_key
    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,        # don't open Preview.app on screenshots
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots"
    )
  end

  desc "Production App Store prep (gated by promote.yml). STOPS before the real submit."
  # Uploads metadata + screenshots + the version's release notes and sets the
  # age rating, then leaves the final, irreversible Submit to Cole in ASC
  # (submit_for_review: false). The binary is the one the beta lane already
  # pushed to TestFlight (skip_binary_upload). Privacy label is one-time manual
  # (see set_age_rating). Marketing version + What's New both derive from the
  # Release Please sources (package.json $.version, CHANGELOG.md).
  lane :app_store do
    api_key = asc_key
    version = marketing_version
    write_release_notes(version)
    set_age_rating
    upload_to_app_store(
      api_key: api_key,
      app_version: version,
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots"
    )
  end

  desc "Generate App Store screenshots for every device-class via XCUItest snapshot lane"
  lane :screenshots do
    capture_screenshots(
      scheme: "AppUITests",
      # Only the screenshot producer — not the whole AppUITests suite
      # (ColdLaunch / Login / DeepLink / …). Mirrors the Snapfile.
      only_testing: ["AppUITests/ScreenshotUITests"],
      devices: [
        "iPhone 17 Pro Max",         # 6.9" (was 6.7")
        "iPhone 17 Pro",             # 6.3"
        "iPad Pro 13-inch (M4)",     # 13"
        "iPad Pro 11-inch (M4)",     # 11"
      ],
      languages: ["en-US"],
      reinstall_app: true,
      concurrent_simulators: false,  # one sim at a time → shared backend isn't contended
      app_identifier: APP_IDENTIFIER,
      output_directory: "fastlane/screenshots"
    )
  end

  desc "Quick build without upload — for local smoke testing"
  lane :build_only do
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Debug",
      export_method: "development",
      skip_archive: true,
      skip_codesigning: true,
      output_directory: "fastlane/builds"
    )
  end

  desc "Sync provisioning profiles from the match repo (read-only on CI)"
  lane :sync_profiles do
    api_key = asc_key
    sign(api_key: api_key)
  end

  desc "Run iOS unit + UI tests across a matrix of simulators"
  lane :test do
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      devices: [
        "iPhone 17 Pro Max",
        "iPad Pro 13-inch (M4)",
        "Apple Watch Ultra 2 (49mm)",
      ],
      code_coverage: true,
      result_bundle: true,
      fail_build: true,
      xcargs: "-skipPackagePluginValidation -skipMacroValidation",
      output_directory: "fastlane/test_output"
    )
  end

  desc "Run iOS + watchOS tests for CI (per-target xccov cobertura + threshold gate)"
  lane :test_ci do
    setup_ci if is_ci
    # Resolve the newest installed iOS + watchOS simulator at runtime so
    # CI tracks whatever the macos-latest image ships. The runner image
    # bumps its sim runtimes over time, so a hardcoded `OS=26.5` would
    # silently break on the next bump -- and `OS=latest` is taken
    # LITERALLY by xcodebuild as a version name, not "whichever's
    # installed". newest_sim_destination (below) picks the highest
    # available runtime + a real device for it. Production WatchApp pins
    # WATCHOS_DEPLOYMENT_TARGET = 10.0 so the bundle stays compatible with
    # everything from watchOS 10+.
    ios_destination = newest_sim_destination("iOS", prefer: "iPhone")
    watch_destination = newest_sim_destination("watchOS")

    # Run iOS schemes sequentially. Each gets its own output_directory so
    # the xcresult bundles don't clobber each other (run_tests would
    # otherwise reuse the same path and the second invocation would fail
    # with "result bundle already exists").
    #
    # SIMCTL_CHILD_CI -- the simulator child process strips most parent
    # env vars by default. SIMCTL_CHILD_<NAME>=value gets re-exposed as
    # <NAME> inside the simulator. WidgetSnapshotTests reads CI via
    # ProcessInfo to decide whether to diff baselines (CI sim version
    # differs from the recording host).
    if is_ci
      ENV["SIMCTL_CHILD_CI"] = "true"
    end
    # Recording baselines: test.yml sets RECORD_MODE=1 on a `record_mode=true`
    # workflow_dispatch. WidgetSnapshotTests / RootViewTests read RECORD_MODE
    # from their PROCESS environment, which on the simulator comes from the
    # scheme's TestAction <EnvironmentVariables> -- SIMCTL_CHILD_* does NOT
    # reach an xcodebuild-launched XCTest process, and xcargs don't expand into
    # scheme-env values. The WidgetTests + WatchTests schemes ship RECORD_MODE
    # disabled; flip it on here for the record run so the tests write fresh
    # baselines (uploaded as an artifact) instead of diffing. Normal runs leave
    # it disabled. The edit is to the runner's checkout only (never committed).
    if ENV["RECORD_MODE"] == "1"
      %w[WidgetTests WatchTests].each do |s|
        scheme_path = "App.xcodeproj/xcshareddata/xcschemes/#{s}.xcscheme"
        xml = File.read(scheme_path)
        xml = xml.sub(/(key = "RECORD_MODE"\s+value = "1"\s+isEnabled = ")NO(")/, '\1YES\2')
        File.write(scheme_path, xml)
        UI.message("RECORD_MODE: enabled snapshot recording in #{s}.xcscheme")
      end
    end
    common_xcargs = "-skipPackagePluginValidation -skipMacroValidation COMPILER_INDEX_STORE_ENABLE=NO DEBUG_INFORMATION_FORMAT=dwarf"

    # Run WatchTests FIRST (different SDK / sim, so its xccov in
    # DerivedData lives at a separate path and won't clobber the iOS
    # entries).
    run_tests(
      project: PROJECT,
      scheme: WATCH_TEST_SCHEME,
      destination: watch_destination,
      code_coverage: true,
      result_bundle: true,
      fail_build: true,
      xcargs: common_xcargs,
      output_directory: "fastlane/test_output/#{WATCH_TEST_SCHEME}"
    )

    # AppTests writes to the default `fastlane/test_output/`; every other
    # scheme goes into its own `fastlane/test_output/<scheme>/`
    # subdirectory so the result bundles don't collide (run_tests refuses
    # to overwrite an existing bundle). The xccov->cobertura step below
    # reads each scheme's bundle from exactly these paths.
    IOS_TEST_SCHEMES.each do |scheme|
      output_dir = (scheme == "AppTests") ? "fastlane/test_output" : "fastlane/test_output/#{scheme}"
      run_tests(
        project: PROJECT,
        scheme: scheme,
        destination: ios_destination,
        code_coverage: true,
        result_bundle: true,
        fail_build: true,
        xcargs: common_xcargs,
        output_directory: output_dir
      )
    end

    # Per-target coverage via `xcrun xccov` -> cobertura + custom gate.
    #
    # One cobertura.xml per scheme, each restricted to that scheme's
    # source dir (see COVERAGE_TARGETS). Output layout:
    #
    #   fastlane/coverage/AppTests/cobertura.xml                (App.app)
    #   fastlane/coverage/AppUITests/cobertura.xml              (App.app, XCUITest)
    #   fastlane/coverage/WidgetTests/cobertura.xml             (AppWidget)
    #   fastlane/coverage/AppLiveActivityTests/cobertura.xml    (AppLiveActivity)
    #   fastlane/coverage/AppShareExtensionTests/cobertura.xml  (AppShareExtension)
    #   fastlane/coverage/WatchTests/cobertura.xml              (WatchApp)
    #
    # codecov-action ingests each under the `ios` flag; the threshold
    # gate (scripts/native/check-ios-coverage.mjs) enforces the per-target
    # floors. We read coverage from `xcrun xccov` rather than slather:
    # slather 2.8.5 emits 0% for every target here because it can't locate
    # the per-line execution data once run_tests writes the result bundle
    # to a custom output_directory (xccov on the same xcresult reports the
    # real coverage). See scripts/native/xccov-to-cobertura.mjs.
    #
    # `sh` runs from this Fastfile's dir (ui/ios/App/fastlane): test_output/
    # + coverage/ are under it, and four `../` reach the repo-root scripts.
    COVERAGE_TARGETS.each do |scheme, source_match|
      xcresult = (scheme == "AppTests") ? "test_output/AppTests.xcresult" : "test_output/#{scheme}/#{scheme}.xcresult"
      sh "node ../../../../scripts/native/xccov-to-cobertura.mjs " \
         "--xcresult #{xcresult} --source-match '#{source_match}' " \
         "--output coverage/#{scheme}/cobertura.xml"
    end

    # Enforce per-target thresholds. Reads each
    # fastlane/coverage/<scheme>/cobertura.xml's root-level `line-rate`
    # attribute and compares against the threshold defined in the script's
    # SCHEMES const. Exit 0 = all pass, 1 = at least one below floor,
    # 2 = at least one cobertura.xml missing.
    # `sh` runs from this Fastfile's dir (ui/ios/App/fastlane). The
    # script lives at <repo-root>/scripts/native/...; four `../` to
    # walk up out of fastlane -> App -> ios -> ui -> repo-root.
    sh "node ../../../../scripts/native/check-ios-coverage.mjs"
  end

  # Build an xcodebuild `-destination` for the NEWEST installed simulator
  # runtime of a platform ("iOS" / "watchOS"), bound to a real available
  # device by UDID. Lets test_ci track whatever the macos-latest image
  # ships without hardcoding a sim version that drifts on image bumps.
  #
  # `prefer` picks a device whose name starts with the given string (e.g.
  # "iPhone" over an iPad) when several exist on the newest runtime;
  # falls back to the first available device. Fails loud if the platform
  # has no available runtime+device -- a missing sim must not silently
  # downgrade the matrix.
  def newest_sim_destination(platform, prefer: nil)
    require "json"
    token = ".#{platform}-" # ".iOS-" / ".watchOS-" in the runtime identifier
    data = JSON.parse(`xcrun simctl list --json devices available`)
    candidates = data.fetch("devices", {}).select { |rt, devs| rt.include?(token) && !devs.empty? }
    UI.user_error!("no available #{platform} simulator runtime+device found") if candidates.empty?
    # Newest runtime = highest version tuple embedded in the identifier
    # (iOS-26-5 > iOS-26-4 > iOS-18-5).
    newest_rt = candidates.keys.max_by do |rt|
      rt[/#{Regexp.escape(token)}(\d+(?:-\d+)*)/, 1].to_s.split("-").map(&:to_i)
    end
    devices = candidates[newest_rt]
    device = (prefer && devices.find { |d| d["name"].to_s.start_with?(prefer) }) || devices.first
    UI.message("#{platform} sim → #{device['name']} on #{newest_rt.split('.').last}")
    "platform=#{platform} Simulator,id=#{device['udid']}"
  end

  # Marketing version (CFBundleShortVersionString) -- the X.Y.Z humans see.
  # Single source of truth is Release Please -> root package.json $.version.
  # Injected via xcargs at build time (see release_xcargs) so every target
  # archives with the released semver, overriding any drifted MARKETING_VERSION
  # literal in project.pbxproj. Fail loud if it can't be read: a release must
  # never ship an unknown version.
  def marketing_version
    require "json"
    pkg = File.expand_path("../../../../package.json", __dir__)
    version = JSON.parse(File.read(pkg))["version"]
    UI.user_error!("no $.version in #{pkg}") if version.to_s.empty?
    version
  end

  # Build settings injected into every release archive. DEVELOPMENT_TEAM is
  # not committed to the pbxproj (CI-only). MARKETING_VERSION comes from
  # package.json so the store version always equals the released semver.
  # The skip flags avoid SPM plugin + macro validation prompts that hang CI.
  def release_xcargs
    "-skipPackagePluginValidation -skipMacroValidation " \
      "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} MARKETING_VERSION=#{marketing_version}"
  end

  # TestFlight changelog for a non-release (dispatch / dev) build: a bulleted
  # list of EVERY commit subject since the last release tag, so "What to Test"
  # reflects everything in the build rather than just the latest commit. Falls
  # back to the whole history when there is no release tag yet, then to the last
  # commit, then to a generic line. Truncated to ASC's 4000-char cap.
  # NB: requires a non-shallow checkout (native-release.yml uses fetch-depth: 0);
  # a depth-1 clone has only HEAD + no tags, which is why this used to show one
  # commit.
  def changelog_for_this_build
    begin
      last_tag = (sh("git describe --tags --abbrev=0 --match 'v*'", log: false).strip rescue "")
      range = last_tag.empty? ? "" : "#{last_tag}..HEAD"
      list = sh("git log #{range} --no-merges --pretty=format:'- %s'", log: false).strip
      list = sh("git log -1 --pretty=%B", log: false).strip if list.empty?
      list = "heron automatic build (#{Time.now.utc.strftime('%Y-%m-%d')})" if list.empty?
      url = changes_url
      # Leave room for the trailing compare link under ASC's 4000-char cap.
      list = list[0...3800] + "..." if list.length > 3800
      url && !url.empty? ? "#{list}\n\nFull changes: #{url}" : list
    rescue
      "heron automatic build (#{Time.now.utc.strftime('%Y-%m-%d')})"
    end
  end

  # GitHub compare (or commits) URL covering everything in this build, appended
  # to the TestFlight notes so testers can click straight to the full diff.
  def changes_url
    remote = (sh("git config --get remote.origin.url", log: false).strip rescue "")
    slug = remote[%r{github\.com[:/](.+?)(?:\.git)?\z}, 1]
    return nil unless slug
    sha = (sh("git rev-parse HEAD", log: false).strip rescue "")
    return nil if sha.empty?
    last_tag = (sh("git describe --tags --abbrev=0 --match 'v*'", log: false).strip rescue "")
    last_tag.empty? ? "https://github.com/#{slug}/commits/#{sha}" : "https://github.com/#{slug}/compare/#{last_tag}...#{sha}"
  end

  # TestFlight "What to Test" source.
  #
  # On a REAL release build (HEAD is exactly the vX.Y.Z tag) internal testers
  # should see the published release notes, so use the CHANGELOG.md section for
  # the current marketing version (the Release Please source, same as the App
  # Store lane).
  #
  # On a dispatch / dev / keepalive build HEAD is AHEAD of the last tag, so the
  # CHANGELOG section for the last released version is STALE -- it describes the
  # prior baseline, not what this build actually contains (e.g. every dispatch
  # of v0.1.0 would otherwise show the "Initial release post-fork" baseline as
  # "What to Test"). The last commit message is what is genuinely being tested,
  # so use it. Always non-empty.
  def testflight_changelog
    if head_is_release_tag?
      notes = release_notes_for_version(marketing_version).to_s.strip
      return notes unless notes.empty? || notes == "Maintenance and improvements."
    end
    commit = changelog_for_this_build.to_s.strip
    return commit unless commit.empty?
    notes = release_notes_for_version(marketing_version).to_s.strip
    notes.empty? ? "Maintenance and improvements." : notes
  end

  # True only when HEAD is checked out exactly at a release tag (tag-push /
  # workflow_call release path). A workflow_dispatch / branch build is ahead of
  # the last tag and returns false, so it uses the commit message above.
  def head_is_release_tag?
    sh("git describe --exact-match --tags HEAD", log: false)
    true
  rescue StandardError
    false
  end

  # App Store "What's New" for a marketing version, pulled from CHANGELOG.md
  # (Release Please maintains it). Extracts the version's section, strips
  # markdown to the plain text the store expects, truncates to ASC's 4000-char
  # cap. Falls back so a release never uploads empty notes.
  def release_notes_for_version(version)
    path = File.expand_path("../../../../CHANGELOG.md", __dir__)
    fallback = "Maintenance and improvements."
    return fallback unless File.exist?(path)
    # Explicit UTF-8: CHANGELOG headers contain non-ASCII (em dash), which
    # throws "invalid byte sequence" if the runner locale defaults to ASCII.
    section = File.read(path, encoding: "UTF-8")[/^##\s*\[#{Regexp.escape(version)}\][^\n]*\n(.*?)(?=^##\s|\z)/m, 1]
    return fallback if section.nil? || section.strip.empty?
    notes = section.strip
      .gsub(/\[([^\]]+)\]\([^)]*\)/, '\1') # [text](url) -> text
      .gsub(/^#+\s+/, "")                   # drop ###-style subheaders
      .gsub(/^\s*[*-]\s+/, "- ")           # normalize bullets
    notes.length > 4000 ? "#{notes[0...3997]}..." : notes
  end

  # Write the version's notes where deliver reads "What's New" (the same
  # en-US metadata dir apply-brand populates).
  def write_release_notes(version)
    require "fileutils"
    dir = File.expand_path("metadata/en-US", __dir__)
    FileUtils.mkdir_p(dir)
    File.write(File.join(dir, "release_notes.txt"), release_notes_for_version(version))
  end

  error do |lane, exception|
    UI.error("Fastlane lane '#{lane}' failed: #{exception.message}")
    if is_ci
      # GitHub Actions annotation so the failure surfaces in the PR view.
      puts "::error title=Fastlane (#{lane}) failed::#{exception.message}"
    end
  end
end
