source "https://rubygems.org"

# Pin Ruby so local dev and CI use the same major. `bundler-cache: true`
# in CI honours `.ruby-version`; locally `rbenv` / `asdf` / `mise` all
# pick it up too.
ruby "~> 3.3"

# Fastlane — bump major version when a new Fastlane release is verified
# against this Fastfile. Pinned to the current major to avoid silent
# breakage from upstream API changes.
gem "fastlane", "~> 2.226"

# Cocoapods is also used by the build pipeline; pinning it here means
# `bundle exec pod install` uses the same version on every machine.
gem "cocoapods", "~> 1.16"

# slather -- profdata -> cobertura.xml converter + per-target coverage
# reporter. Runs once PER SCHEME (AppTests, WidgetTests,
# AppLiveActivityTests, AppShareExtensionTests, WatchTests) with
# `--binary-basename` filtering, producing one cobertura.xml per binary
# at `fastlane/coverage/<scheme>/cobertura.xml`. The codecov-action
# uploads each XML under the `ios` flag; `scripts/native/check-ios-coverage.mjs`
# (invoked at the end of the Fastlane test_ci lane) enforces per-target
# thresholds (95% App.app + 50% extensions/watch). Pulls nokogiri as a
# transitive (native-compiled gem; ~30s install on a cold runner, cached
# via the bundler-gems cache step in test.yml).
#
# xcov was previously used as the threshold gate but xcov 1.9.0 cannot
# read xcresult bundles from non-default paths (we write per-scheme
# output_directory), so it was unable to gate the non-default schemes.
# It's been removed in favour of slather + the custom threshold script
# (one tool, per-target accuracy).
gem "slather"

plugins_path = File.join(File.dirname(__FILE__), "fastlane", "Pluginfile")
eval_gemfile(plugins_path) if File.exist?(plugins_path)
