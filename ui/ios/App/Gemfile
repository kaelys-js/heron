source "https://rubygems.org"

# Pin Ruby so local dev and CI use the same major. `bundler-cache: true`
# in CI honours `.ruby-version`; locally `rbenv` / `asdf` / `mise` all
# pick it up too.
ruby "~> 3.3"

# Fastlane — bump major version when a new Fastlane release is verified
# against this Fastfile. Pinned to the current major to avoid silent
# breakage from upstream API changes.
gem "fastlane", "~> 2.226"

# Cocoapods is also used by the build pipeline; pinning it here means
# `bundle exec pod install` uses the same version on every machine.
gem "cocoapods", "~> 1.16"

# xcov -- code-coverage threshold gate. Reads the xcresult bundle from
# run_tests + emits HTML for humans + checks `minimum_coverage_percentage`.
# CANNOT generate cobertura.xml: the xcov gem (1.9.0) only exposes
# html_report / markdown_report / json_report; no XML output. Standalone
# gem (NOT a fastlane plugin -- those must be named fastlane-plugin-*).
# Bundler loading is sufficient -- fastlane's action loader picks the
# action up at startup.
gem "xcov"

# slather -- profdata -> cobertura.xml converter for the Codecov upload
# step in .github/workflows/test.yml. xcov above gates the iOS coverage
# threshold; slather is the only piece producing the cobertura.xml that
# the codecov-action `hashFiles(...)` predicate looks for. Pulls
# nokogiri as a transitive (native-compiled gem; ~30s install on a cold
# runner, cached via the bundler-gems cache step in test.yml).
gem "slather"

plugins_path = File.join(File.dirname(__FILE__), "fastlane", "Pluginfile")
eval_gemfile(plugins_path) if File.exist?(plugins_path)
