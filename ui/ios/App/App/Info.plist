<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Career Ops</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- arm64 only — armv7 (32-bit) hasn't shipped since the iPhone 5. -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- iPad multitasking: don't force fullscreen (false = Split View +
	     Slide Over + Stage Manager work). Capacitor uses a single Scene
	     so we don't declare a SceneManifest; iOS's default single-scene
	     behaviour is correct here. -->
	<key>UIRequiresFullScreen</key>
	<false/>

	<!-- Stage Manager (iPadOS 16+) — opt in to the resizable window
	     experience. Together with UIRequiresFullScreen=false this lets
	     the user open career-ops alongside Mail / Calendar / Notes. -->
	<key>UISupportsTrueScreenSizeOnMac</key>
	<true/>

	<!-- ===== career-ops customizations ===== -->

	<!-- Custom URL scheme: careerops://job/abc opens the app. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.resistjs.careerops</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>careerops</string>
			</array>
		</dict>
	</array>

	<!-- Local network access — for mDNS Bonjour discovery of the desktop
	     career-ops server on the same wifi. Without this string iOS shows
	     a permission prompt with no explanation. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Career Ops uses local network discovery to find your desktop app on the same Wi-Fi network so your phone, watch, and laptop stay in sync without a cloud account.</string>

	<!-- Bonjour service types we want to browse for. iOS 14+ requires
	     this allowlist to be declared up-front. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_career-ops._tcp</string>
	</array>

	<!-- Background modes — keep SSE connection alive briefly when backgrounded,
	     and allow background-fetch every 15min for high-priority Issues
	     when SSE has dropped. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>

	<!-- App Transport Security: allow http:// to local servers (Capacitor
	     server cleartext = true mirrors this on the JS side). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<!-- Tailscale magic-DNS hostnames are *.ts.net. -->
			<key>ts.net</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- Face ID usage description (Phase 3.6) -->
	<key>NSFaceIDUsageDescription</key>
	<string>Career Ops uses Face ID to unlock sensitive screens — interview notes, negotiation playbooks, and offer comparisons — so a glance over your shoulder never leaks personal data.</string>

	<!-- Spotlight indexing description -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.resistjs.careerops.job</string>
		<string>com.resistjs.careerops.openJob</string>
	</array>

	<!-- ===== 2026 best-practice additions ===== -->

	<!-- App Store category — used by Spotlight, "open with" dialogs, and
	     TestFlight metadata even when not on the App Store. -->
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>

	<!-- Export compliance — TestFlight asks every build whether it uses
	     non-exempt encryption. career-ops uses only standard HTTPS/TLS
	     which Apple treats as exempt. Setting this to false in Info.plist
	     suppresses the per-upload prompt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- We're not a document-browser app -->
	<key>UISupportsDocumentBrowser</key>
	<false/>

	<!-- Trackpad / Magic Keyboard support on iPad — interpret pointer
	     events as discrete inputs rather than touch-equivalents. -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- ProMotion 120Hz on iPhone 13 Pro+ / iPad Pro — allow the WebView
	     to render above 60Hz. -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- Copyright (shown in About/legal screens generated by some tools) -->
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 santifer</string>

	<!-- Mock-interview voice capture uses MediaRecorder which iOS WebView
	     routes through the native mic permission. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Career Ops uses the microphone for the mock-interview rehearsal mode — audio is processed on-device and never uploaded.</string>

	<!-- Avatar upload via file picker — system asks for Photos access. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Career Ops needs photo-library access to attach screenshots of job postings or reference letters to a job entry.</string>

	<!-- Calendar integration — interview reminders can write to Calendar
	     when you've enabled it in settings. -->
	<key>NSCalendarsUsageDescription</key>
	<string>Career Ops reads your calendar to surface upcoming interviews and to schedule follow-up reminders.</string>
</dict>
</plist>
