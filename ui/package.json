{
  "name": "ui",
  "version": "1.6.0",
  "private": true,
  "description": "Career Ops SvelteKit dashboard — multi-user, multi-platform (web + iOS + Android + Electron).",
  "homepage": "https://career-ops.org",
  "bugs": {
    "url": "https://github.com/kaelys-js/career-ops/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelys-js/career-ops",
    "directory": "ui"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "brand": "node ../scripts/native/apply-brand.mjs",
    "build": "vite build",
    "build:static": "CAPACITOR=1 PUBLIC_CAPACITOR_BUILD=1 vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
    "check:warn": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean": "node ../scripts/clean.mjs",
    "dev": "vite dev",
    "go": "vite dev --open",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "typecheck:watch": "tsgo --noEmit -p tsconfig.json --watch",
    "verify": "node ../verify-capacitor.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.1",
    "@better-auth/passkey": "1.6.10",
    "@capacitor/app-launcher": "8.0.1",
    "@capacitor/browser": "8.0.3",
    "@capacitor/clipboard": "8.0.1",
    "@capacitor/device": "8.0.2",
    "@capacitor/dialog": "8.0.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/push-notifications": "8.0.4",
    "@capacitor/screen-reader": "8.0.1",
    "@internationalized/date": "3.12.1",
    "@lucide/svelte": "1.14.0",
    "better-auth": "1.6.10",
    "better-sqlite3": "12.9.0",
    "chokidar": "5.0.0",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "gray-matter": "4.0.3",
    "imapflow": "1.3.3",
    "isomorphic-dompurify": "3.12.0",
    "mode-watcher": "1.1.0",
    "svelte-sonner": "1.1.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "yaml": "2.8.4"
  },
  "devDependencies": {
    "@capacitor-community/electron": "5.0.1",
    "@capacitor/android": "8.3.3",
    "@capacitor/app": "8.1.0",
    "@capacitor/cli": "8.3.3",
    "@capacitor/core": "8.3.3",
    "@capacitor/ios": "8.3.3",
    "@capacitor/local-notifications": "8.1.0",
    "@capacitor/network": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "bits-ui": "2.18.1",
    "drizzle-kit": "0.31.10",
    "marked": "18.0.3",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.2",
    "sharp": "0.34.5",
    "svelte": "5.55.5",
    "svelte-check": "4.4.8",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.12"
  },
  "engines": {
    "node": "26.1.0",
    "pnpm": "11.1.0"
  }
}
