# NPM renames .gitignore to .npmignore
# In order to prevent that, we remove the initial "."
# And the CLI then renames it
app
node_modules
# Generated outputs only — the entitlements.{mac,mas}.plist files in
# build/ are hand-edited source config, kept tracked via the root
# .gitignore negation rules.
build/src/
build/lib/
build/types/
build/icon*
build/capacitor.config.*
dist
logs
# Generated at build time by scripts/native/gen-build-info.mjs (commit /
# buildDate / channel / changelog notes). Regenerated before every tsgo
# compile; never committed so it can't churn the working tree.
src/build-info.ts
