{
  "name": "heron",
  "version": "0.1.0",
  "private": true,
  "description": "Heron desktop — Electron shell embedding the SvelteKit dashboard.",
  "keywords": [
    "capacitor",
    "electron",
    "heron",
    "desktop"
  ],
  "homepage": "https://heron.app",
  "bugs": {
    "url": "https://github.com/heron/heron/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heron/heron",
    "directory": "ui/electron"
  },
  "license": "MIT",
  "author": {
    "name": "resist.js",
    "email": "hello@heron.app",
    "url": "https://heron.app"
  },
  "main": "build/src/index.js",
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "build:tsc": "tsc",
    "check": "pnpm lint && pnpm typecheck",
    "clean": "node ../../scripts/system/clean.mjs",
    "electron:make": "pnpm run build && electron-builder build -c ./electron-builder.config.json -p always",
    "electron:make:dev": "pnpm run build && electron-builder build -c ./electron-builder.config.json --mac dmg --publish never",
    "electron:pack": "pnpm run build && electron-builder build --dir -c ./electron-builder.config.json",
    "electron:start": "pnpm run build && electron --inspect=5858 ./",
    "electron:start-live": "node ./live-runner.js",
    "lint": "oxlint --config ../../.oxlintrc.jsonc .",
    "lint:fix": "oxlint --fix --config ../../.oxlintrc.jsonc .",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@capacitor-community/electron": "5.0.1",
    "bonjour-service": "1.3.0",
    "chokidar": "4.0.3",
    "electron-is-dev": "catalog:",
    "electron-serve": "catalog:",
    "electron-unhandled": "4.0.1",
    "electron-updater": "6.8.3",
    "electron-window-state": "5.0.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "@vitest/coverage-v8": "catalog:",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "26.1.0",
    "pnpm": "11.1.0"
  }
}
