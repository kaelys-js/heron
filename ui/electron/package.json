{
  "name": "career-ops",
  "version": "1.6.0",
  "private": true,
  "description": "Career Ops desktop — Electron shell embedding the SvelteKit dashboard.",
  "keywords": [
    "capacitor",
    "electron",
    "career-ops",
    "desktop"
  ],
  "homepage": "https://career-ops.org",
  "bugs": {
    "url": "https://github.com/kaelys-js/career-ops/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelys-js/career-ops",
    "directory": "ui/electron"
  },
  "license": "MIT",
  "author": {
    "name": "resist.js",
    "email": "hello@resist.js",
    "url": "https://resist.js"
  },
  "main": "build/src/index.js",
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "build:tsc": "tsc",
    "check": "tsgo --noEmit -p tsconfig.json",
    "clean": "node ../../scripts/clean.mjs",
    "electron:make": "pnpm run build && electron-builder build -c ./electron-builder.config.json -p always",
    "electron:make:dev": "pnpm run build && electron-builder build -c ./electron-builder.config.json --mac dmg --publish never",
    "electron:pack": "pnpm run build && electron-builder build --dir -c ./electron-builder.config.json",
    "electron:start": "pnpm run build && electron --inspect=5858 ./",
    "electron:start-live": "node ./live-runner.js",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@capacitor-community/electron": "5.0.1",
    "bonjour-service": "1.3.0",
    "chokidar": "4.0.3",
    "electron-is-dev": "2.0.0",
    "electron-serve": "1.3.0",
    "electron-unhandled": "4.0.1",
    "electron-updater": "6.8.3",
    "electron-window-state": "5.0.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "26.1.0",
    "pnpm": "11.1.0"
  }
}
