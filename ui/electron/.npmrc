# ui/electron/.npmrc — local overrides for `npm install` in this directory.
#
# The repo root `.npmrc` is full of pnpm-10-specific tuning
# (`side-effects-cache`, `node-linker=isolated`, `prefer-frozen-lockfile`,
# `dedupe-peer-dependents`, etc.). When the dev-desktop script falls back
# to `npm install` here (because Electron has to live in its own non-
# workspace node_modules), npm reads the SAME .npmrc walking up the tree
# and inherits options that either:
#   • make no sense to npm (it ignores them; harmless), or
#   • cause silent skip of postinstall scripts under certain combinations
#     of `--silent` + `engine-strict=true`.
#
# Most importantly: `engine-strict=true` combined with `--silent` in the
# parent npm process can suppress the error from electron's postinstall
# script when Node's version doesn't perfectly match electron's declared
# engines range — and electron's postinstall is what downloads the
# ~150 MB binary AND writes `path.txt`. Without `path.txt` the runtime
# throws "Electron failed to install correctly" the moment you start it.
#
# These overrides keep npm noisy + permissive enough that the install
# either succeeds visibly or fails visibly. No silent half-installs.

# Run postinstall scripts (this is npm's default but explicit here so a
# rogue env var can't disable it).
ignore-scripts=false

# Don't fail on engines mismatch — electron's postinstall is a download
# script, it doesn't actually exercise the engine range.
engine-strict=false

# Show postinstall output instead of swallowing it. If electron's
# download fails, the error appears in the log.
foreground-scripts=true

# Keep audit / fund noise out (matches the script's --no-audit --no-fund).
audit=false
fund=false
