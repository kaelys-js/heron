{
  "$schema": "./node_modules/app-builder-lib/scheme.json",
  "appId": "com.resistjs.careerops",
  "productName": "Career Ops",
  "copyright": "© 2026 resist.js (original work © 2026 santifer). Licensed under the MIT License.",
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": ["assets/**/*", "build/**/*", "capacitor.config.*", "app/**/*"],
  "extraResources": [
    {
      "from": "../build/index.js",
      "to": "app/server/index.js"
    },
    {
      "from": "../build",
      "to": "app/server",
      "filter": ["**/*", "!**/static/**"]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "kaelys-js",
      "repo": "career-ops",
      "releaseType": "release"
    }
  ],
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "mac": {
    "category": "public.app-category.productivity",
    "minimumSystemVersion": "12.0",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": false,
    "darkModeSupport": true,
    "extendInfo": {
      "CFBundleURLTypes": [
        {
          "CFBundleURLName": "careerops",
          "CFBundleURLSchemes": ["careerops"]
        }
      ],
      "LSApplicationCategoryType": "public.app-category.productivity",
      "LSMinimumSystemVersion": "12.0",
      "NSLocalNetworkUsageDescription": "Career Ops uses local network discovery to find your desktop app on the same Wi-Fi network so your phone, watch, and laptop stay in sync without a cloud account.",
      "NSBonjourServices": ["_career-ops._tcp"],
      "NSMicrophoneUsageDescription": "career-ops uses your microphone for mock interview voice recording.",
      "NSCalendarsUsageDescription": "career-ops adds your interviews to Calendar when reminders are enabled.",
      "NSHumanReadableCopyright": "© 2026 resist.js (original work © 2026 santifer). Licensed under the MIT License.",
      "NSSupportsAutomaticTermination": true,
      "NSSupportsSuddenTermination": true,
      "NSAppleScriptEnabled": false,
      "NSHighResolutionCapable": true
    }
  },
  "dmg": {
    "writeUpdateInfo": true,
    "sign": false,
    "title": "${productName} ${version}",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.ico",
    "publisherName": "resist.js",
    "verifyUpdateCodeSignature": false,
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "allowElevation": false,
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "menuCategory": "Productivity",
    "shortcutName": "Career Ops",
    "differentialPackage": true,
    "deleteAppDataOnUninstall": false,
    "displayLanguageSelector": false
  },
  "appx": {
    "applicationId": "careerops",
    "displayName": "Career Ops",
    "publisher": "CN=resist.js",
    "publisherDisplayName": "resist.js",
    "identityName": "resist.js.careerops",
    "backgroundColor": "#0a0a0b"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "deb",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.png",
    "category": "Office;Network;Development",
    "synopsis": "Run your job search like a product launch.",
    "description": "Career Ops is an AI-powered job search platform: multi-user dashboard, autonomous apply across 11 ATS portals, tailored CVs and cover letters per role, interview prep, follow-up cadence, and offline-first native apps on macOS, Windows, Linux, iOS, iPadOS, Android, and Apple Watch.",
    "maintainer": "resist.js <hello@resist.js>",
    "vendor": "resist.js",
    "executableName": "career-ops",
    "desktop": {
      "entry": {
        "Name": "Career Ops",
        "GenericName": "Job Search Pipeline",
        "Comment": "Run your job search like a product launch.",
        "Keywords": "career;jobs;ai;automation;applications;",
        "MimeType": "x-scheme-handler/careerops;",
        "StartupNotify": "true",
        "StartupWMClass": "career-ops"
      }
    }
  },
  "deb": {
    "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"],
    "priority": "optional"
  },
  "appImage": {
    "license": "MIT"
  },
  "protocols": [
    {
      "name": "careerops",
      "schemes": ["careerops"],
      "role": "Editor"
    }
  ]
}
