{
  "$schema": "./node_modules/app-builder-lib/scheme.json",
  "appId": "com.resistjs.heron",
  "productName": "Heron",
  "copyright": "© 2026 Heron contributors (original work © 2026 santifer). Licensed under the MIT License.",
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": ["assets/**/*", "build/**/*", "capacitor.config.*", "app/**/*"],
  "extraResources": [
    {
      "from": "../build/index.js",
      "to": "app/server/index.js"
    },
    {
      "from": "../build",
      "to": "app/server",
      "filter": ["**/*", "!**/static/**"]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "kaelys-js",
      "repo": "heron",
      "releaseType": "release"
    }
  ],
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "mac": {
    "category": "public.app-category.productivity",
    "minimumSystemVersion": "12.0",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "mas",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": true,
    "darkModeSupport": true,
    "extendInfo": {
      "CFBundleURLTypes": [
        {
          "CFBundleURLName": "heron",
          "CFBundleURLSchemes": ["heron"]
        }
      ],
      "LSApplicationCategoryType": "public.app-category.productivity",
      "LSMinimumSystemVersion": "12.0",
      "NSLocalNetworkUsageDescription": "Heron uses local network discovery to find your desktop app on the same Wi-Fi network so your phone, watch, and laptop stay in sync without a cloud account.",
      "NSBonjourServices": ["_heron._tcp"],
      "NSMicrophoneUsageDescription": "Heron uses your microphone for mock interview voice recording.",
      "NSCalendarsUsageDescription": "Heron adds your interviews to Calendar when reminders are enabled.",
      "NSHumanReadableCopyright": "© 2026 Heron contributors (original work © 2026 santifer). Licensed under the MIT License.",
      "NSSupportsAutomaticTermination": true,
      "NSSupportsSuddenTermination": true,
      "NSAppleScriptEnabled": false,
      "NSHighResolutionCapable": true
    }
  },
  "mas": {
    "category": "public.app-category.productivity",
    "icon": "build/icon.icns",
    "entitlements": "build/entitlements.mas.plist",
    "entitlementsInherit": "build/entitlements.mas.inherit.plist",
    "provisioningProfile": "build/embedded.provisionprofile",
    "darkModeSupport": true,
    "hardenedRuntime": true
  },
  "dmg": {
    "writeUpdateInfo": true,
    "sign": true,
    "title": "${productName} ${version}",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "appx",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.ico",
    "verifyUpdateCodeSignature": true,
    "requestedExecutionLevel": "asInvoker",
    "signtoolOptions": {
      "signingHashAlgorithms": ["sha256"],
      "publisherName": "resist.js",
      "rfc3161TimeStampServer": "http://timestamp.digicert.com",
      "timeStampServer": "http://timestamp.digicert.com"
    }
  },
  "nsis": {
    "allowElevation": false,
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "menuCategory": "Productivity",
    "shortcutName": "Heron",
    "differentialPackage": true,
    "deleteAppDataOnUninstall": false,
    "displayLanguageSelector": false
  },
  "appx": {
    "applicationId": "heron",
    "displayName": "Heron",
    "publisher": "CN=resist.js",
    "publisherDisplayName": "resist.js",
    "identityName": "resist.js.heron",
    "backgroundColor": "#0e1014"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "deb",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.png",
    "category": "Office;Network;Development",
    "synopsis": "Stand still. Strike well.",
    "description": "Heron is a thinking partner for career transitions. Local-first job-search platform: pipeline tracking, A-F role evaluation, ATS-optimized CVs, 11-portal scanning, recruiter email triage, interview prep, and opt-in autonomous apply. Runs on macOS, Windows, Linux, iOS, iPadOS, Android, and Apple Watch.",
    "maintainer": "resist.js <hello@heron.app>",
    "vendor": "resist.js",
    "executableName": "heron",
    "desktop": {
      "entry": {
        "Name": "Heron",
        "GenericName": "Job Search Pipeline",
        "Comment": "Stand still. Strike well.",
        "Keywords": "career;jobs;ai;automation;applications;",
        "MimeType": "x-scheme-handler/heron;",
        "StartupNotify": "true",
        "StartupWMClass": "heron"
      }
    }
  },
  "deb": {
    "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"],
    "priority": "optional"
  },
  "appImage": {
    "license": "MIT"
  },
  "protocols": [
    {
      "name": "heron",
      "schemes": ["heron"],
      "role": "Editor"
    }
  ]
}
