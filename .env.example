# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# All keys are loaded by the dashboard at startup. You can also set them
# from the UI: localhost:5174/settings or via the onboarding wizard's
# "API keys" step on first run.

# ── Anthropic (REQUIRED) ──────────────────────────────────────────────────
# Powers Claude — used for deep job evaluations, agent chat, mock interviews,
# interview prep, negotiation drafts, CV-tailoring, cover letters, and the
# plain-text → markdown CV converter in onboarding.
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Gemini (RECOMMENDED) ─────────────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.0-flash (no billing needed)
# Used for first-pass scoring on the daily ~30 new postings before deeper
# Claude evaluation — keeps API costs low.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# Default: gemini-2.0-flash (free tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-thinking-exp
# GEMINI_MODEL=gemini-2.0-flash

# ── Adzuna (OPTIONAL) ────────────────────────────────────────────────────
# Adds Adzuna to the JobSpy aggregator list. Skip unless you specifically
# want Adzuna's coverage. Sign up: https://developer.adzuna.com
# ADZUNA_APP_ID=your_app_id
# ADZUNA_APP_KEY=your_app_key

# ── Gmail IMAP (OPTIONAL) ────────────────────────────────────────────────
# Real-time job-alert ingestion. Polls a Gmail label every 30 min via IMAP
# and parses LinkedIn / Indeed / generic alert emails into the pipeline.
#
# Setup:
#   1. Enable 2-factor auth on your Google account
#   2. Generate an app password at https://myaccount.google.com/apppasswords
#      (pick "Mail" + "Other (custom name)" → "career-ops")
#   3. Optional: in Gmail create a filter that auto-applies a label to
#      LinkedIn/Indeed alert emails (e.g. "career-ops/job-alerts"), then
#      point GMAIL_IMAP_LABEL at that label instead of INBOX
#   4. Or use the /sources page (or onboarding "Sources" step) to set
#      these up via UI — credentials are written here automatically
#
# GMAIL_IMAP_HOST=imap.gmail.com
# GMAIL_IMAP_USER=you@gmail.com
# GMAIL_IMAP_PASSWORD=xxxx_xxxx_xxxx_xxxx
# GMAIL_IMAP_LABEL=INBOX

# ── Other integrations (add your own below) ──────────────────────────────
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
