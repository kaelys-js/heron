# Example env vars for `act` — copy to .env.act (gitignored) and fill in.
#
# act reads .env.act per the --env-file flag in .actrc. These vars
# show up in the workflow's `env:` context just like GitHub Secrets,
# so secrets-using workflows can run end-to-end locally.
#
# NEVER commit real secrets here. .env.act is in .gitignore by default,
# but double-check before pushing.

# ── Tests workflow (test.yml) ──────────────────────────────────────
# The verifier's deterministic seed. Any 32+ char string works locally.
BETTER_AUTH_SECRET=local-act-secret-do-not-use-in-production-32chars
BETTER_AUTH_RATE_LIMIT=off

# ── Native release workflow (native-release.yml) ──────────────────
# Skip locally unless you're testing the iOS build pipeline.
# Apple App Store Connect API key (base64 .p8 content):
# APPLE_API_KEY=
# APPLE_API_KEY_ID=
# APPLE_API_ISSUER_ID=

# Apple ID + Team — used by fastlane match for signing artefacts:
# APPLE_ID=
# APPLE_TEAM_ID=

# ── Release-please / publishing ────────────────────────────────────
# act's GITHUB_TOKEN is auto-filled from `gh auth token` via the
# `--secret-file` flag below if you wire it; otherwise the release
# workflow's `gh release create` step won't actually publish.
# GITHUB_TOKEN=<gh auth token output>

# ── Other ─────────────────────────────────────────────────────────
# act always sets ACT=true so workflows can detect they're running
# locally. The test workflow checks this to skip the security-audit
# gate (pnpm audit hits npmjs.org and is slow on cold cache).
ACT=true
