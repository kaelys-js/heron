{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "branding/brand.json",
    "branding/logo.svg",
    "package.json",
    ".mise.toml",
    "biome.json"
  ],
  "globalEnv": ["NODE_ENV", "CAPACITOR", "PUBLIC_CAPACITOR_BUILD", "APPLE_ID", "APPLE_TEAM_ID"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "brand"],
      "outputs": ["build/**", ".svelte-kit/**", "dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/*.test.ts"]
    },
    "build:static": {
      "dependsOn": ["brand"],
      "env": ["CAPACITOR", "PUBLIC_CAPACITOR_BUILD"],
      "outputs": ["build/static/**"]
    },
    "brand": {
      "inputs": [
        "branding/brand.json",
        "branding/logo.svg",
        "scripts/native/apply-brand.mjs",
        "native/icons/generate-icons.mjs"
      ],
      "outputs": [
        "ui/src/lib/client/brand.ts",
        "ui/electron/src/brand.ts",
        "ui/static/manifest.webmanifest",
        "ui/static/favicon.svg",
        "ui/static/favicon.ico",
        "ui/static/icons/**",
        "ui/capacitor.config.ts",
        "ui/electron/capacitor.config.ts",
        "ui/electron/electron-builder.config.json",
        "ui/electron/build/icon.*",
        "ui/electron/build/icon-*.png",
        "ui/ios/App/App/Info.plist",
        "ui/ios/App/App/Brand.swift",
        "ui/ios/App/App/Assets.xcassets/AppIcon.appiconset/**",
        "ui/ios/App/CareerOpsWidget/Brand.swift",
        "ui/ios/App/CareerOpsLiveActivity/Brand.swift",
        "ui/ios/App/CareerOpsShareExtension/Brand.swift",
        "ui/android/app/src/main/res/mipmap-*/**",
        "ui/android/app/src/main/res/values/strings.xml",
        "ui/ios/App/fastlane/Appfile",
        "ui/ios/App/fastlane/Fastfile",
        "scripts/native/add-xcode-targets.rb",
        "native/icons/_build/**"
      ]
    },
    "check": {
      "dependsOn": ["brand"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "verify": {
      "dependsOn": ["brand"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["brand"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "dependsOn": ["^build"]
    }
  }
}
