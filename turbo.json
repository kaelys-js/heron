{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "stream",

  "globalDependencies": [
    "branding/brand.json",
    "branding/logo.svg",
    "package.json",
    ".mise.toml",
    "biome.jsonc",
    "pnpm-workspace.yaml",
    ".npmrc"
  ],
  "globalEnv": ["NODE_ENV", "CAPACITOR", "PUBLIC_CAPACITOR_BUILD", "APPLE_ID", "APPLE_TEAM_ID"],

  "tasks": {
    "build": {
      "dependsOn": ["^build", "brand"],
      "outputs": ["build/**", ".svelte-kit/**", "dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/*.test.ts",
        "!**/*.spec.ts",
        "!**/CHANGELOG.md",
        "!**/TODO.md"
      ]
    },

    "build:static": {
      "dependsOn": ["brand"],
      "env": ["CAPACITOR", "PUBLIC_CAPACITOR_BUILD"],
      "outputs": ["build/static/**"],
      "inputs": [
        "src/**",
        "static/**",
        "svelte.config.ts",
        "vite.config.ts",
        "tsconfig.json",
        "package.json"
      ]
    },

    "brand": {
      "inputs": [
        "branding/brand.json",
        "branding/logo.svg",
        "scripts/native/apply-brand.mjs",
        "scripts/native/icons/generate-icons.mjs"
      ],
      "outputs": [
        "ui/src/lib/client/brand.ts",
        "ui/electron/src/brand.ts",
        "ui/static/manifest.webmanifest",
        "ui/static/favicon.svg",
        "ui/static/favicon.ico",
        "ui/static/icons/**",
        "ui/capacitor.config.ts",
        "ui/electron/capacitor.config.ts",
        "ui/electron/electron-builder.config.json",
        "ui/electron/build/icon.*",
        "ui/electron/build/icon-*.png",
        "ui/ios/App/App/Info.plist",
        "ui/ios/App/App/Brand.swift",
        "ui/ios/App/App/Assets.xcassets/AppIcon.appiconset/**",
        "ui/ios/App/Extensions/AppWidget/Brand.swift",
        "ui/ios/App/Extensions/AppLiveActivity/Brand.swift",
        "ui/ios/App/Extensions/AppShareExtension/Brand.swift",
        "ui/android/app/src/main/res/mipmap-*/**",
        "ui/android/app/src/main/res/values/strings.xml",
        "ui/ios/App/fastlane/Appfile",
        "ui/ios/App/fastlane/Fastfile",
        "scripts/native/add-xcode-targets.rb",
        "scripts/native/icons/_build/**"
      ]
    },

    "typecheck": {
      "dependsOn": ["brand"],
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.svelte",
        "src/**/*.js",
        "src/**/*.mjs",
        "src/**/*.d.ts",
        "src/app.html",
        "static/**",
        "svelte.config.ts",
        "vite.config.ts",
        "tsconfig.json",
        ".svelte-kit/tsconfig.json",
        "package.json"
      ]
    },

    "lint": {
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.svelte",
        "src/**/*.js",
        "src/**/*.mjs",
        "src/**/*.d.ts",
        "../.oxlintrc.jsonc",
        "../../.oxlintrc.jsonc",
        "package.json"
      ]
    },

    "lint:fix": {
      "cache": false,
      "outputs": []
    },

    "check": {
      "dependsOn": ["lint", "typecheck"],
      "outputs": []
    },

    "format": {
      "cache": false
    },

    "format:check": {
      "outputs": [],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.svelte",
        "**/*.json",
        "**/*.jsonc",
        "**/*.yaml",
        "**/*.yml",
        "biome.jsonc",
        "**/.prettierrc",
        "**/.prettierrc.json",
        ".prettierignore"
      ]
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["brand"]
    },

    "test": {
      "dependsOn": ["brand"],
      "outputs": [".vitest-cache/**"],
      "inputs": [
        "src/**",
        "static/**",
        "vite.config.ts",
        "vitest.config.ts",
        "vitest.workspace.ts",
        "tsconfig.json",
        "package.json"
      ]
    },

    "test:coverage": {
      "dependsOn": ["brand"],
      // Coverage MUST run fresh every time. v8 coverage is sensitive to
      // worker timing + GC + JIT state, so cached `coverage-summary.json`
      // can show measurably lower coverage than a fresh re-run (saw
      // 2-3% drops between cached and fresh on identical source). The
      // restored cache also includes the FAILING run's outputs (turbo
      // caches by input hash regardless of task exit code), so a
      // historical fail gets replayed forever until a meaningful input
      // change. `cache: false` opts out -- the task always runs.
      "cache": false,
      "outputs": ["coverage/**"]
    },

    "test:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["brand"]
    },

    "test:watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["brand"]
    },

    "//#test:ios": {
      "outputs": ["ui/ios/App/fastlane/test_output/**", "ui/ios/App/fastlane/coverage/**"],
      "inputs": [
        "ui/ios/App/**/*.swift",
        "ui/ios/App/**/Info.plist",
        "ui/ios/App/**/*.entitlements",
        "ui/ios/App/App.xcodeproj/project.pbxproj",
        "ui/ios/App/fastlane/Fastfile",
        "ui/ios/App/Gemfile.lock"
      ]
    }
  }
}
