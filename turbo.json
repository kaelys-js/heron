{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "stream",

  "globalDependencies": [
    "branding/brand.json",
    "branding/logo.svg",
    "package.json",
    ".mise.toml",
    "biome.jsonc",
    "pnpm-workspace.yaml",
    ".npmrc"
  ],
  "globalEnv": ["NODE_ENV", "CAPACITOR", "PUBLIC_CAPACITOR_BUILD", "APPLE_ID", "APPLE_TEAM_ID"],

  "remoteCache": { "signature": true },

  "tasks": {
    "build": {
      "dependsOn": ["^build", "//#brand"],
      "outputs": ["build/**", ".svelte-kit/**", "dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/*.test.ts",
        "!**/*.spec.ts",
        "!**/CHANGELOG.md",
        "!**/TODO.md"
      ]
    },

    "build:static": {
      "dependsOn": ["//#brand"],
      "env": ["CAPACITOR", "PUBLIC_CAPACITOR_BUILD"],
      "outputs": ["build/static/**"],
      "inputs": [
        "src/**",
        "static/**",
        "svelte.config.ts",
        "vite.config.ts",
        "tsconfig.json",
        "package.json"
      ]
    },

    "//#brand": {
      "inputs": [
        "branding/brand.json",
        "branding/logo.svg",
        "scripts/native/apply-brand.mjs",
        "scripts/native/icons/generate-icons.mjs"
      ],
      "outputs": [
        "ui/src/lib/client/brand.ts",
        "ui/electron/src/brand.ts",
        "ui/static/manifest.webmanifest",
        "ui/static/favicon.svg",
        "ui/static/favicon.ico",
        "ui/static/icons/**",
        "ui/capacitor.config.ts",
        "ui/electron/capacitor.config.ts",
        "ui/electron/electron-builder.config.json",
        "ui/electron/build/icon.*",
        "ui/electron/build/icon-*.png",
        "ui/ios/App/App/Info.plist",
        "ui/ios/App/App/Brand.swift",
        "ui/ios/App/App/Assets.xcassets/AppIcon.appiconset/**",
        "ui/ios/App/Extensions/AppWidget/Brand.swift",
        "ui/ios/App/Extensions/AppLiveActivity/Brand.swift",
        "ui/ios/App/Extensions/AppShareExtension/Brand.swift",
        "ui/android/app/src/main/res/mipmap-*/**",
        "ui/android/app/src/main/res/values/strings.xml",
        "ui/ios/App/fastlane/Appfile",
        "ui/ios/App/fastlane/Fastfile",
        "scripts/native/add-xcode-targets.rb",
        "scripts/native/icons/_build/**"
      ]
    },

    "typecheck": {
      "dependsOn": ["//#brand"],
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.svelte",
        "src/**/*.js",
        "src/**/*.mjs",
        "src/**/*.d.ts",
        "src/app.html",
        "static/**",
        "svelte.config.ts",
        "vite.config.ts",
        "tsconfig.json",
        ".svelte-kit/tsconfig.json",
        "package.json"
      ]
    },

    "lint": {
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.svelte",
        "src/**/*.js",
        "src/**/*.mjs",
        "src/**/*.d.ts",
        "../.oxlintrc.jsonc",
        "../../.oxlintrc.jsonc",
        "package.json"
      ]
    },

    "lint:fix": {
      "cache": false,
      "outputs": []
    },

    "check": {
      "dependsOn": ["lint", "typecheck"],
      "outputs": []
    },

    "format": {
      "cache": false
    },

    "format:check": {
      "outputs": [],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.svelte",
        "**/*.json",
        "**/*.jsonc",
        "**/*.yaml",
        "**/*.yml",
        "biome.jsonc",
        "**/.prettierrc",
        "**/.prettierrc.json",
        ".prettierignore"
      ]
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["//#brand"]
    },

    "test": {
      "dependsOn": ["//#brand"],
      "outputs": [".vitest-cache/**"],
      "inputs": [
        "src/**",
        "static/**",
        "vite.config.ts",
        "vitest.config.ts",
        "vitest.base.ts",
        "tsconfig.json",
        "package.json"
      ]
    },

    "test:coverage": {
      "dependsOn": ["//#brand"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "static/**",
        "vite.config.ts",
        "vitest.config.ts",
        "vitest.base.ts",
        "tsconfig.json",
        "package.json"
      ]
    },

    "test:ui": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["//#brand"]
    },

    "test:watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["//#brand"]
    },

    "//#test:ios": {
      "outputs": ["ui/ios/App/fastlane/test_output/**", "ui/ios/App/fastlane/coverage/**"],
      "inputs": [
        "ui/ios/App/**/*.swift",
        "ui/ios/App/**/Info.plist",
        "ui/ios/App/**/*.entitlements",
        "ui/ios/App/App.xcodeproj/project.pbxproj",
        "ui/ios/App/fastlane/Fastfile",
        "ui/ios/App/Gemfile.lock"
      ]
    },

    "//#verify:no-slop": {
      "outputs": [],
      "inputs": [
        "**/*.md",
        "**/*.{ts,tsx,svelte,mjs,js,cjs}",
        "**/*.py",
        "**/*.rb",
        "**/*.{sh,bash}",
        "**/*.{yml,yaml}",
        "scripts/system/verify-no-slop.mjs",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**",
        "!**/.gradle/**",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#verify:comment-style": {
      "outputs": [],
      "inputs": [
        "**/*.{ts,tsx,svelte,mjs,js,cjs}",
        "scripts/system/verify-comment-style.mjs",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**"
      ]
    },

    "//#verify:english-only": {
      "outputs": [],
      "inputs": [
        "**/*.md",
        "**/*.{ts,tsx,svelte,mjs}",
        "**/*.{py,sh,rb}",
        "scripts/system/verify-english-only.mjs",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#verify:modes": {
      "outputs": [],
      "inputs": ["modes/**/*.md", "scripts/system/verify-modes.mjs"]
    },

    "//#verify:merge-markers": {
      "outputs": [],
      "inputs": [
        "**/*",
        "scripts/system/verify-merge-markers.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**",
        "!**/.gradle/**",
        "!**/*.test.*",
        "!**/*.spec.*",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#validate:exact-versions": {
      "outputs": [],
      "inputs": [
        "package.json",
        "ui/package.json",
        "ui/electron/package.json",
        ".mise.toml",
        "scripts/system/validate-exact-versions.mjs"
      ]
    },

    "//#validate:version-sync": {
      "outputs": [],
      "inputs": [
        "package.json",
        "ui/package.json",
        "ui/electron/package.json",
        "VERSION",
        ".release-please-manifest.json",
        "scripts/system/validate-version-sync.mjs"
      ]
    },

    "//#validate:format-sync": {
      "outputs": [],
      "inputs": [
        ".editorconfig",
        "biome.jsonc",
        ".prettierrc.json",
        "scripts/system/validate-format-config-sync.mjs"
      ]
    },

    "//#validate:json-schemas": {
      "outputs": [],
      "inputs": [
        "**/*.{json,jsonc}",
        "scripts/system/validate-json-schemas.mjs",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**",
        "!**/.gradle/**",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#validate:lockfile": {
      "outputs": [],
      "inputs": ["pnpm-lock.yaml", "scripts/system/validate-pnpm-lockfile.mjs"]
    },

    "//#validate:pnpm-scripts": {
      "outputs": [],
      "inputs": [
        ".github/workflows/**/*.{yml,yaml}",
        "**/*.md",
        "**/*.{sh,bash}",
        "lefthook.yml",
        "turbo.json",
        "package.json",
        "ui/package.json",
        "ui/electron/package.json",
        "scripts/system/verify-pnpm-scripts.mjs",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#validate:csp-hashes": {
      "outputs": [],
      "inputs": ["ui/src/app.html", "ui/svelte.config.ts", "scripts/system/verify-csp-hashes.mjs"]
    },

    "//#validate:tiny-configs": {
      "outputs": [],
      "inputs": [
        ".gitattributes",
        ".npmrc",
        ".actrc",
        "LICENSE",
        "ui/static/robots.txt",
        "scripts/system/validate-tiny-configs.mjs"
      ]
    },

    "//#fonts:verify": {
      "outputs": [],
      "inputs": ["ui/static/fonts/**", "scripts/system/verify-fonts.mjs"]
    },

    "//#validate:workflows": {
      "outputs": [],
      "inputs": [".github/workflows/*.{yml,yaml}", "scripts/system/verify-workflow-quality.mjs"]
    },

    "//#validate:markdown": {
      "outputs": [],
      "inputs": [
        "**/*.md",
        ".markdownlint-cli2.jsonc",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.svelte-kit/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/coverage/**",
        "!**/test-results/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**",
        "!**/.gradle/**",
        "!data/**",
        "!reports/**",
        "!output/**"
      ]
    },

    "//#validate:xml": {
      "outputs": [],
      "inputs": [
        "**/*.svg",
        "**/*.storyboard",
        "scripts/system/validate-xml.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**"
      ]
    },

    "//#lint:swift": {
      "outputs": [],
      "inputs": ["ui/ios/App/**/*.swift", ".swiftlint.yml", "scripts/system/lint-native.sh"]
    },

    "//#lint:kotlin": {
      "outputs": [],
      "inputs": [
        "**/*.kt",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/.gradle/**"
      ]
    },

    "//#lint:python": {
      "outputs": [],
      "inputs": [
        "**/*.py",
        "pyproject.toml",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/.venv/**",
        "!**/build/**",
        "!**/dist/**"
      ]
    },

    "//#lint:shell": {
      "outputs": [],
      "inputs": [
        "**/*.{sh,bash}",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**"
      ]
    },

    "//#lint:ruby": {
      "outputs": [],
      "inputs": [
        "**/*.rb",
        "Gemfile",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**"
      ]
    },

    "//#lint:toml": {
      "outputs": [],
      "inputs": [
        "**/*.toml",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**",
        "!**/.venv/**"
      ]
    },

    "//#lint:yaml": {
      "outputs": [],
      "inputs": [
        "**/*.{yml,yaml}",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**"
      ]
    },

    "//#lint:dotenv": {
      "outputs": [],
      "inputs": [".env.example", ".env.act.example", "scripts/system/lint-native.sh"]
    },

    "//#lint:plist": {
      "outputs": [],
      "inputs": [
        "**/*.{plist,entitlements,xcprivacy}",
        "scripts/system/validate-plists.py",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/DerivedData/**",
        "!**/SourcePackages/**",
        "!**/Pods/**"
      ]
    },

    "//#lint:actionlint": {
      "outputs": [],
      "inputs": [
        ".github/workflows/**/*.{yml,yaml}",
        "**/*.{sh,bash}",
        "scripts/system/lint-native.sh",
        "!**/node_modules/**",
        "!**/.turbo/**",
        "!**/build/**",
        "!**/dist/**"
      ]
    }
  }
}
