# EditorConfig — universal text-editor settings.
# https://editorconfig.org
#
# Picked up automatically by VS Code, JetBrains, vim, emacs, Sublime,
# nano, Xcode (via a plugin), and Android Studio. The settings here
# DELIBERATELY mirror biome.jsonc + .prettierrc.json so saving a file
# in your editor produces output that already passes the lefthook
# pre-commit gate.
#
# If you change any of the values below, mirror the change in
# biome.jsonc (formatter.{indentStyle,indentWidth,lineWidth,lineEnding}
# block + javascript.formatter block) AND .prettierrc.json so .svelte
# files stay in sync with .ts. Drift between these three files is the
# #1 cause of "the editor formats it differently than the hook" pain.

root = true

[*]
charset                  = utf-8
indent_style             = space
indent_size              = 2
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
max_line_length          = 100

# ── Languages that traditionally use tabs or wider indents ──────────
[*.{md,mdx}]
# Markdown trailing whitespace is meaningful (two spaces = <br>).
trim_trailing_whitespace = false
max_line_length          = off

[Makefile]
indent_style = tab

[*.{go,proto}]
indent_style = tab

[*.{swift,kt,kts,gradle}]
indent_size = 4

[*.{kt,kts}]
# Brand.kt is auto-generated by apply-brand and mirrors the camelCase
# naming used in the Swift + TypeScript brand constants
# (Brand.bundleId, etc.). Disable ktlint's screaming-snake-case rule
# for top-level `const val`s so the three brand-as-code files stay in
# lock-step. Re-enable selectively if/when human-authored Kotlin code
# grows beyond apply-brand's outputs.
ktlint_standard_property-naming = disabled

[*.{py,rb}]
indent_size = 4

[*.{xml,plist,xcconfig,xcsettings,xcscheme,xcworkspacedata,pbxproj}]
indent_size              = 4
trim_trailing_whitespace = false

# ── Files we never reformat ─────────────────────────────────────────
[{*.lock,*.tsbuildinfo,*.snap,*.min.*,**/CHANGELOG.md,**/pnpm-lock.yaml,**/Gemfile.lock,**/Package.resolved}]
indent_size              = unset
indent_style             = unset
trim_trailing_whitespace = false
insert_final_newline     = unset
