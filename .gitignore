# Personal data (user fills these)
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv

# Server runtime state — never commit. activity.jsonl is rotated at 50MB
# (see ui/src/lib/server/events.ts) but a runaway log can still hit GB
# before rotation kicks in; the file regenerates per session anyway.
# Caches are deterministic outputs of analyze-patterns / followup-cadence.
data/activity.jsonl
data/activity.jsonl.1
data/issues.jsonl
data/followup-cache.json
data/insights-cache.json
data/patterns-cache.json
data/autopilot.json
data/sources.json
data/onboarding-state.json
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# Reset / rollback backups (resetProfile() writes <path>.bak before
# overwriting; previously these were accidentally tracked, so a fresh
# reset always dirtied the worktree). Files stay on disk as actual
# backups — just never committed.
*.bak
*.bak.*

# Per-profile user data — dashboard manages this on boot; same reason
# config/profile.yml / cv.md / portals.yml are gitignored.
data/profiles/

# Autonomous-apply system runtime state.
data/apply-state/

# Daily backups (tar.gz snapshots — local-only by design).
data/backups/

# Playwright persistent contexts — browser session data per portal.
.playwright-*/

# OS
.DS_Store
*.mov
*.mp4

# Python
__pycache__/
*.pyc

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json