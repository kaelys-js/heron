coverage/
*.lcov
.nyc_output/
.vitest/
.vitest-attachments/
**/.vitest-attachments/
test-results/
playwright-report/
# Vitest browser-mode failure screenshots — regenerated on each run.
**/__screenshots__/
playwright/.cache/
*.tap

# ── Native build artefacts ──────────────────────────────────────────
*.dmg
*.exe
*.AppImage
*.pkg
*.deb
*.rpm
*.snap
*.apk
*.aab
*.ipa
DerivedData/

# ── Native signing / store secrets ──────────────────────────────────
# Keystores, properties files, App Store Connect API keys, Google Play
# service-account JSONs — NEVER commit these. CI loads via repo secrets.
*.keystore
*.jks
*.p12
*.p8
*.mobileprovision
*.cer
*.certSigningRequest
keystore.properties
google-services.json
GoogleService-Info.plist
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/coverage/
fastlane/builds/
fastlane/screenshots/**/*.png
fastlane/screenshots/**/*.jpg
!fastlane/screenshots/README.md
# auto-generated by `bundle exec fastlane` on first run; not maintained
fastlane/README.md
fastlane/metadata/
# Also match nested fastlane dirs (e.g. ui/ios/App/fastlane/) -- the
# unrooted patterns above don't recurse on their own when run from
# repo root with the nested path.
**/fastlane/README.md
**/fastlane/metadata/
**/fastlane/report.xml

# ── SBOM outputs ────────────────────────────────────────────────────
sbom-*.json
sbom-*.xml
*.spdx.json
*.cdx.json

# ── Media (auto-generated, not source) ──────────────────────────────
*.mov
*.mp4

