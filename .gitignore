.claude/settings.local.json
.claude/memory/
career-dashboard
.claude/scheduled_tasks.lock
ui/electron/.svelte-kit/ambient.d.ts
ui/electron/.svelte-kit/tsconfig.json
ui/electron/.svelte-kit/generated/client/app.js
ui/electron/.svelte-kit/generated/client/matchers.js
