*.cer
*.certSigningRequest
keystore.properties
google-services.json
GoogleService-Info.plist
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/coverage/
fastlane/builds/
fastlane/screenshots/**/*.png
fastlane/screenshots/**/*.jpg
!fastlane/screenshots/README.md

