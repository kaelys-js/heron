# ── Build / tooling caches — deterministic outputs, never commit ────
.turbo/
**/.turbo/
**/.cache/
**/.vite/
**/.parcel-cache/
ui/.svelte-kit/
ui/build/
ui/electron/dist/
# Electron build directory: ignore everything generated, KEEP the hand-edited
# entitlements + electron-builder config (they're source, not artefacts).
ui/electron/build/icon*
ui/electron/build/capacitor.config.*
!ui/electron/build/entitlements.mac.plist
!ui/electron/build/entitlements.mas.plist
scripts/native/icons/_build/
*.tsbuildinfo

# ── Personal data (user fills these) ────────────────────────────────
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv

# ── Server runtime state — never commit ─────────────────────────────
# activity.jsonl is rotated at 50MB (see ui/src/lib/server/events.ts)
# but a runaway log can still hit GB before rotation kicks in; the file
# regenerates per session anyway.
# Caches are deterministic outputs of analyze-patterns / followup-cadence.
data/activity.jsonl
data/activity.jsonl.1
data/issues.jsonl
data/followup-cache.json
data/insights-cache.json
data/patterns-cache.json
data/autopilot.json
data/sources.json
data/onboarding-state.json
# Multi-profile config — lists the user's profiles + which one is
# active. Per-install state, regenerated on first boot via
# profile-migrate. Was tracked by mistake previously; `git rm --cached`
# removed it from the index. Treat the same as the other data/*.json
# runtime files above.
data/profiles.json
# Repo-root user dirs (reports/, output/, jds/, writing-samples/,
# interview-prep/) historically were compatibility symlinks managed
# by the now-deleted profile-symlinks.ts. Option-C plowdown replaced
# the symlink mechanism with spawn-time path substitution (see
# modes/_TOKENS.md + ui/src/lib/server/mode-substitution.ts). The
# dirs may still be created incidentally by old scripts; ignore them
# so they never sneak into a commit.
reports
output
jds
interview-prep
writing-samples
# Note: per-profile batch runtime state (batch-input.tsv, batch-state.tsv,
# logs/, tracker-additions/*.tsv) lives under
# data/{users/{uid}/}profiles/{slug}/batch/ and is already covered by the
# data/ ignore above. Repo-root batch/ no longer exists post-multi-user
# migration — the system-layer batch-prompt.md moved to templates/ and
# the orchestrator script moved to scripts/batch/.

# ── User config and customization (never auto-updated) ──────────────
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# ── Secrets (never commit — use .env.example as template) ───────────
.env
.env.*
!.env.example
!.env.test
!.env.act.example
*.pem
*.key
*.p12
*.p8
*.mobileprovision
*.provisionprofile
.envrc

# ── Generated / cache outputs ───────────────────────────────────────
.resolved-prompt-*
node_modules/
.pnpm-store/

# Refuse other package managers' lockfiles outright — preinstall guard
# (scripts/ensure-pnpm.mjs) already blocks npm/yarn/bun. The lockfiles
# would just be stale artifacts if they ever appeared.
package-lock.json
yarn.lock
bun.lock
bun.lockb

# ── Reset / rollback backups ────────────────────────────────────────
# resetProfile() writes <path>.bak before overwriting; previously these
# were accidentally tracked, so a fresh reset always dirtied the worktree.
# Files stay on disk as actual backups — just never committed.
*.bak
*.bak.*
# resetProfile()'s timestamped snapshot dirs — created automatically
# before any destructive `pnpm reset:data` run. These contain WHOLE
# user profiles (CVs, applications, reports, form-answer caches with
# real emails). NEVER commit. The pattern matches both flavours the
# dashboard has emitted historically.
data/.reset-bak-*/
data/.reset-bak-*
**/.reset-bak-*/
**/.reset-bak-*

# ── Per-profile user data ───────────────────────────────────────────
# Dashboard manages this on boot; same reason config/profile.yml /
# cv.md / portals.yml are gitignored.
data/profiles/

# Multi-user per-user content tree + the legacy-claim sentinel.
data/users/

# ── SQLite runtime state ────────────────────────────────────────────
# auth.db has session cookies + passkey credentials, app.db has every
# per-user profile/job/report/etc. Never commit.
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# ── Autonomous-apply system runtime state ───────────────────────────
data/apply-state/

# ── Daily backups (tar.gz snapshots — local-only by design) ─────────
data/backups/

# ── Per-user avatar uploads ─────────────────────────────────────────
data/avatars/

# ── Per-user UI prefs (legacy single-user file; migrated into app.db) ─
data/ui-prefs.json

# ── Playwright persistent contexts — browser session data per portal ─
.playwright-*/

# ── OS-specific cruft ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE caches ─────────────────────────────────────────────
# .vscode/ kept globally — repo ships shared workspace settings.
# .idea/ entirely ignored — JetBrains caches per-user state.
.idea/
*.swp
*.swo
*.swn
*.~lock.*
*~
.netrwhist

