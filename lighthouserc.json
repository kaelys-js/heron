{
  "$schema": "https://googlechrome.github.io/lighthouse-ci/schemas/lhr-config.json",
  "_comment": "HP2 — Lighthouse CI budgets for the SvelteKit dashboard. Audits /login (cold start) + 3 authenticated routes (/inbox, /queue, /autopilot). The workflow injects an Authorization header via the e2e-login bypass so Lighthouse can render the auth-gated routes without going through the passkey flow.",

  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter ui exec vite preview --port 4173",
      "startServerReadyPattern": "Local: +http://localhost:4173",
      "url": [
        "http://localhost:4173/login",
        "http://localhost:4173/inbox",
        "http://localhost:4173/queue",
        "http://localhost:4173/autopilot"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2", "is-on-https", "redirects-http"],
        "chromeFlags": "--no-sandbox --headless=new",
        "_comment_extra_headers": "Workflow runs scripts/system/inject-lighthouse-auth.mjs which clones this config to lighthouserc.runtime.json with extraHeaders.Authorization populated from the e2e-login token. The auth-gated URLs above only render correctly with a valid bearer token; without it they 302 to /login and the redirects audit fails."
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "interaction-to-next-paint": ["warn", { "maxNumericValue": 200 }],
        "speed-index": ["warn", { "maxNumericValue": 3000 }],
        "uses-rel-preconnect": "off",
        "uses-text-compression": "off",

        "is-crawlable": "off",
        "redirects": ["error", { "minScore": 1 }],
        "redirects-http": "off",
        "inspector-issues": "off",
        "forced-reflow-insight": "off",
        "document-latency-insight": "off",
        "network-dependency-tree-insight": "off",
        "unused-javascript": ["warn", { "maxLength": 0 }],
        "errors-in-console": ["error", { "minScore": 1 }],
        "color-contrast": ["warn", { "minScore": 0.9 }],
        "label-content-name-mismatch": ["warn", { "minScore": 0.9 }],
        "heading-order": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
