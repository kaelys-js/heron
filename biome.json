{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "**/*",
      "!**/node_modules/**",
      "!**/.svelte-kit/**",
      "!**/build/**",
      "!**/dist/**",
      "!**/.turbo/**",
      "!**/.vite/**",
      "!**/coverage/**",
      "!**/.next/**",
      "!**/.cache/**",
      "!**/_build/**",
      "!ui/electron/build/**",
      "!ui/electron/dist/**",
      "!ui/electron/app/**",
      "!ui/ios/App/Pods/**",
      "!ui/ios/App/App.xcodeproj/**",
      "!ui/ios/App/build/**",
      "!ui/ios/App/DerivedData/**",
      "!ui/ios/App/output/**",
      "!ui/android/.gradle/**",
      "!ui/android/build/**",
      "!ui/android/app/build/**",
      "!ui/android/app/src/main/assets/**",
      "!**/*.bak",
      "!**/*.tsbuildinfo",
      "!data/**",
      "!reports/**",
      "!output/**",
      "!batch/**",
      "!jds/**",
      "!writing-samples/**",
      "!.playwright-*/**",
      "!.venv/**",
      "!venv/**",
      "!ui/ios/App/App/Brand.swift",
      "!ui/ios/App/CareerOpsWidget/Brand.swift",
      "!ui/ios/App/CareerOpsLiveActivity/Brand.swift",
      "!ui/ios/App/CareerOpsShareExtension/Brand.swift",
      "!ui/src/lib/client/brand.ts",
      "!ui/electron/src/brand.ts",
      "!CHANGELOG.md",
      "!pnpm-lock.yaml",
      "!**/Gemfile.lock",
      "!**/Package.resolved",
      "!**/*.svelte",
      "!**/*.css",
      "!**/*.scss",
      "!ui/ios/App/App/Assets.xcassets/**",
      "!ui/ios/App/CareerOpsWatch/Assets.xcassets/**",
      "!**/AppIcon.appiconset/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf",
    "formatWithErrors": false
  },
  "linter": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
