#!/usr/bin/env bash
# career-ops pre-commit hook.
#
# Auto-runs `apply-brand` when any branding/ file (brand.json, logo.svg)
# is staged. Then re-stages the propagated files so the commit captures
# both the brand change AND its downstream effects atomically.
#
# Enable once with:  git config core.hooksPath .githooks
# (Setup wizard offers to do this for you.)

set -e

# Anything staged under branding/?
if git diff --cached --name-only | grep -q '^branding/'; then
  echo "[pre-commit] branding/ change detected — running apply-brand"
  node scripts/native/apply-brand.mjs > /dev/null 2>&1 || {
    echo "[pre-commit] apply-brand failed — aborting commit"
    exit 1
  }
  # Re-stage every file that apply-brand might have touched.
  git add \
    package.json \
    ui/electron/package.json \
    ui/capacitor.config.ts \
    ui/electron/capacitor.config.ts \
    ui/electron/electron-builder.config.json \
    ui/ios/App/App/Info.plist \
    ui/ios/App/App/Brand.swift \
    ui/ios/App/CareerOpsWidget/Brand.swift \
    ui/ios/App/CareerOpsLiveActivity/Brand.swift \
    ui/ios/App/CareerOpsShareExtension/Brand.swift \
    ui/src/lib/client/brand.ts \
    ui/electron/src/brand.ts \
    ui/static/favicon.svg \
    ui/static/manifest.webmanifest \
    ui/src/app.html \
    ui/ios/App/fastlane/Appfile \
    ui/ios/App/fastlane/Fastfile \
    scripts/native/add-xcode-targets.rb \
    2>/dev/null || true
  echo "[pre-commit] propagated files re-staged"
fi
