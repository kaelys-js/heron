# pnpm settings — repo-wide.
#
# Documented at https://pnpm.io/npmrc — every flag here either
# (a) makes installs faster / smaller, or
# (b) tightens a default that's loose for security/correctness.

# ── Lockfile hygiene ────────────────────────────────────────────────
# `pnpm install` in CI must error out if pnpm-lock.yaml would change.
# Local dev still updates the lockfile freely; CI just guarantees the
# committed lockfile is what got installed.
prefer-frozen-lockfile=true

# Don't leak warnings into the installer output for deprecated transitive
# deps we can't fix — they show up loud in pnpm audit instead.
loglevel=warn

# ── Linker / hoisting ───────────────────────────────────────────────
# pnpm 10's default is `isolated` (each package gets a private node_modules
# of symlinks). Explicit so the choice survives future default changes.
node-linker=isolated

# Hardlink files from the global store into each project's node_modules.
# Roughly 10× faster than copy on macOS/Linux and disk-cheap.
package-import-method=hardlink

# When two workspace packages depend on the same peer (e.g. `react`),
# resolve them to one shared version where possible. Saves duplicates.
dedupe-peer-dependents=true

# Auto-install peer deps instead of warning — pnpm 8+ default but explicit
# so older pnpm versions get the same behaviour.
auto-install-peers=true

# ── Engine + manager guards ─────────────────────────────────────────
# Refuse to install if the running pnpm/Node violates `engines`. Pairs
# with scripts/ensure-pnpm.mjs (the preinstall guard that refuses npm).
engine-strict=true

# pnpm 10 doesn't auto-run install scripts of transitive deps by default
# (security best practice). Better-sqlite3 + sharp need theirs to compile
# native bindings; we approve them explicitly in pnpm-workspace.yaml.
side-effects-cache=true
side-effects-cache-readonly=false

# ── Network ─────────────────────────────────────────────────────────
# Retry on flaky network — sensible CI default.
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
network-concurrency=16

# ── Misc ────────────────────────────────────────────────────────────
# Quiet the per-package "deprecated" notices — `pnpm outdated` is the
# right surface for that.
package-manager-strict=false

# Honor the `peerDependenciesMeta` declarations in package.json (a few
# Better Auth peers are explicitly optional).
strict-peer-dependencies=false
