# Prettier only formats .svelte files in heron. Biome handles everything
# else. Even so, give prettier an ignore file so it never accidentally
# touches unrelated content if the script is misconfigured.

# ── Build outputs / caches ──────────────────────────────────────────
node_modules/
.svelte-kit/
build/
dist/
.turbo/
.vite/
ui/electron/build/
ui/electron/dist/
ui/electron/app/
**/_build/

# ── Native build outputs ────────────────────────────────────────────
ui/ios/App/Pods/
ui/ios/App/App.xcodeproj/
ui/ios/App/App/Assets.xcassets/
ui/ios/App/build/
ui/ios/App/DerivedData/
ui/ios/App/output/
ui/android/.gradle/
ui/android/build/
ui/android/app/build/
ui/android/app/src/main/assets/

# ── User-owned data ─────────────────────────────────────────────────
data/
reports/
output/
batch/
jds/

# ── Generated / vendored ────────────────────────────────────────────
**/*.bak
**/*.tsbuildinfo
CHANGELOG.md
pnpm-lock.yaml

# ── Brand-generated files (auto-rewritten by apply-brand.mjs) ───────
ui/ios/App/App/Brand.swift
ui/ios/App/Extensions/AppWidget/Brand.swift
ui/ios/App/Extensions/AppLiveActivity/Brand.swift
ui/ios/App/Extensions/AppShareExtension/Brand.swift
ui/src/lib/client/brand.ts
ui/electron/src/brand.ts

# ── File-type allowlist (only Svelte goes through prettier) ─────────
# Globs below tell prettier to skip everything that ISN'T .svelte —
# Biome (faster, no AST cost) handles the rest.
