{
  "name": "career-ops",
  "version": "1.6.0",
  "description": "AI-powered job search pipeline",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "doctor": "node doctor.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "scan": "node scan.mjs",
    "gemini:eval": "node gemini-eval.mjs",
    "native": "node scripts/native/help.mjs",
    "setup:native": "node scripts/native/setup.mjs",
    "setup:secrets": "node scripts/native/setup.mjs",
    "dev": "turbo dev --filter=ui",
    "dev:desktop": "node scripts/native/dev-desktop.mjs",
    "dev:ios": "node scripts/native/dev-ios.mjs",
    "build": "turbo build",
    "build:static": "turbo build:static",
    "build:desktop": "node scripts/native/build-desktop.mjs",
    "build:ios": "node scripts/native/build-ios-testflight.mjs",
    "icons": "node scripts/native/icons.mjs",
    "release": "node scripts/native/release.mjs",
    "brand:apply": "node scripts/native/apply-brand.mjs",
    "format": "biome format --write . && pnpm -C ui exec prettier --write \"**/*.svelte\" --ignore-path ../.prettierignore",
    "format:check": "biome format . && pnpm -C ui exec prettier --check \"**/*.svelte\" --ignore-path ../.prettierignore",
    "format:svelte": "pnpm -C ui exec prettier --write \"**/*.svelte\" --ignore-path ../.prettierignore",
    "check": "turbo check",
    "verify:capacitor": "node verify-capacitor.mjs",
    "reset:data": "node scripts/reset-data.mjs",
    "prepare": "lefthook install || true",
    "preinstall": "node scripts/ensure-pnpm.mjs"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "santifer <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "dotenv": "16.6.1",
    "js-yaml": "4.1.1",
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "turbo": "2.9.12"
  }
}
