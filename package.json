{
  "name": "career-ops",
  "version": "1.6.0",
  "description": "Career Ops is an AI-powered job search platform: multi-user dashboard, autonomous apply across 11 ATS portals, tailored CVs and cover letters per role, interview prep, follow-up cadence, and offline-first native apps on macOS, Windows, Linux, iOS, iPadOS, Android, and Apple Watch.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=26.0.0",
    "pnpm": ">=11.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "author": "resist.js <hello@resist.js> (https://resist.js)",
  "license": "MIT",
  "homepage": "https://career-ops.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelys-js/career-ops"
  },
  "bugs": {
    "url": "https://github.com/kaelys-js/career-ops/issues"
  },
  "funding": "https://github.com/sponsors/kaelys-js",
  "keywords": [
    "ai-agent",
    "anthropic",
    "automation",
    "better-auth",
    "capacitor",
    "career",
    "claude",
    "claude-code",
    "drizzle-orm",
    "electron",
    "interview-prep",
    "ios",
    "job-search",
    "open-source",
    "passkey",
    "resume",
    "svelte",
    "sveltekit",
    "typescript",
    "watchos"
  ],
  "scripts": {
    "doctor": "node doctor.mjs",
    "doctor:native": "node scripts/native/doctor.mjs",
    "doctor:native:offline": "node scripts/native/doctor.mjs --no-remote",
    "ats:check": "node ats-check.mjs",
    "verify": "node verify-pipeline.mjs",
    "verify:capacitor": "node verify-capacitor.mjs",
    "verify:multi-user": "node verify-multi-user.mjs",
    "verify:pipeline": "node verify-pipeline.mjs",
    "verify:all": "node verify-pipeline.mjs && node verify-capacitor.mjs && node verify-multi-user.mjs",
    "verify:cached": "turbo run //#verify:all",
    "verify:capacitor:cached": "turbo run //#verify:capacitor",
    "verify:multi-user:cached": "turbo run //#verify:multi-user",
    "verify:pipeline:cached": "turbo run //#verify:pipeline",
    "act:list": "act --list",
    "act:test": "act push --workflows .github/workflows/test.yml",
    "act:test:dry": "act push --workflows .github/workflows/test.yml --dryrun",
    "act:codeql": "act push --workflows .github/workflows/codeql.yml --matrix language:javascript-typescript",
    "act:labeler": "act pull_request --workflows .github/workflows/labeler.yml",
    "act:sbom": "act push --workflows .github/workflows/sbom.yml",
    "act:dependency-review": "act pull_request --workflows .github/workflows/dependency-review.yml",
    "test": "node test-all.mjs",
    "test:quick": "node test-all.mjs --quick",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "scan": "node scan.mjs",
    "gemini:eval": "node gemini-eval.mjs",
    "native": "node scripts/native/help.mjs",
    "setup:native": "node scripts/native/setup.mjs",
    "setup:secrets": "node scripts/native/setup.mjs",
    "dev": "turbo dev --filter=ui",
    "dev:desktop": "node scripts/native/dev-desktop.mjs",
    "dev:ios": "node scripts/native/dev-ios.mjs",
    "build": "turbo build",
    "build:static": "turbo build:static",
    "build:desktop": "node scripts/native/build-desktop.mjs",
    "build:ios": "node scripts/native/build-ios-testflight.mjs",
    "check": "turbo check",
    "typecheck": "turbo check",
    "icons": "node scripts/native/icons.mjs",
    "release": "node scripts/native/release.mjs",
    "brand:apply": "node scripts/native/apply-brand.mjs",
    "format": "biome format --write . && pnpm -C ui exec prettier --write \"**/*.svelte\" --ignore-path ../.prettierignore",
    "format:check": "biome format . && pnpm -C ui exec prettier --check \"**/*.svelte\" --ignore-path ../.prettierignore",
    "format:svelte": "pnpm -C ui exec prettier --write \"**/*.svelte\" --ignore-path ../.prettierignore",
    "lint": "pnpm format:check",
    "lint:fix": "pnpm format",
    "audit": "pnpm dlx pnpm@latest audit",
    "outdated": "pnpm outdated -r",
    "clean": "node scripts/clean.mjs",
    "clean:cache": "pnpm dlx rimraf .turbo ui/.svelte-kit ui/build ui/electron/build ui/electron/dist",
    "reset:data": "node scripts/reset-data.mjs",
    "prepare": "lefthook install || true",
    "preinstall": "node scripts/ensure-pnpm.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "dotenv": "16.6.1",
    "js-yaml": "4.1.1",
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "turbo": "2.9.12"
  }
}
