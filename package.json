{
  "name": "heron",
  "version": "0.1.0",
  "private": true,
  "description": "Heron is a thinking partner for career transitions. Local-first job-search platform: pipeline tracking, A-F role evaluation, ATS-optimized CVs, 11-portal scanning, recruiter email triage, interview prep, and opt-in autonomous apply. Runs on macOS, Windows, Linux, iOS, iPadOS, Android, and Apple Watch.",
  "keywords": [
    "ai-agent",
    "anthropic",
    "automation",
    "better-auth",
    "capacitor",
    "career",
    "claude",
    "claude-code",
    "drizzle-orm",
    "electron",
    "heron",
    "interview-prep",
    "ios",
    "job-search",
    "local-first",
    "open-source",
    "passkey",
    "resume",
    "svelte",
    "sveltekit",
    "typescript",
    "watchos"
  ],
  "homepage": "https://heron.app",
  "bugs": {
    "url": "https://github.com/kaelys-js/heron/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelys-js/heron"
  },
  "funding": "https://github.com/sponsors/kaelys-js",
  "license": "MIT",
  "author": "resist.js <hello@heron.app> (https://heron.app)",
  "type": "module",
  "scripts": {
    "act:codeql": "act push --workflows .github/workflows/codeql.yml --matrix language:javascript-typescript",
    "act:dependency-review": "act pull_request --workflows .github/workflows/dependency-review.yml",
    "act:labeler": "act pull_request --workflows .github/workflows/labeler.yml",
    "act:list": "act --list",
    "act:sbom": "act push --workflows .github/workflows/sbom.yml",
    "act:test": "act push --workflows .github/workflows/test.yml",
    "act:test:dry": "act push --workflows .github/workflows/test.yml --dryrun",
    "ai-detect:check": "node scripts/cv/ai-detect-check.mjs",
    "app-css-block:test": "node scripts/native/app-css-block.test.mjs",
    "ats:check": "node scripts/cv/ats-check.mjs",
    "audit": "pnpm audit",
    "brand": "node scripts/native/apply-brand.mjs",
    "brand:apply": "node scripts/native/apply-brand.mjs",
    "build": "bash scripts/system/mise-shim.sh turbo build",
    "build:desktop": "node scripts/native/build-desktop.mjs",
    "build:desktop:fast": "node scripts/native/build-desktop.mjs --fast",
    "build:ios": "node scripts/native/build-ios-testflight.mjs",
    "build:static": "turbo build:static",
    "check": "bash scripts/system/mise-shim.sh turbo check",
    "clean": "node scripts/system/clean.mjs",
    "clean:cache": "rm -rf .turbo ui/.svelte-kit ui/build ui/electron/build ui/electron/dist",
    "cover:check": "node scripts/quality/cover-letter-check.mjs",
    "dedup": "node scripts/tracker/dedup-tracker.mjs",
    "dev": "turbo dev --filter=ui",
    "dev:android": "node scripts/native/dev-android.mjs",
    "dev:apple-watch": "node scripts/native/dev-apple-watch.mjs",
    "dev:desktop": "node scripts/native/dev-desktop.mjs",
    "dev:ios": "node scripts/native/dev-ios.mjs",
    "discord:config:test": "node scripts/system/apply-discord-config.test.mjs",
    "doctor": "node scripts/system/doctor.mjs",
    "doctor:native": "node scripts/native/doctor.mjs",
    "e2e": "pnpm --filter ui exec playwright install --with-deps chromium && pnpm --filter ui test:e2e",
    "fonts:lock": "node scripts/system/verify-fonts.mjs --update",
    "fonts:verify": "node scripts/system/verify-fonts.mjs",
    "format": "bash scripts/system/mise-shim.sh sh -c 'biome format --write . && pnpm -C ui exec prettier --write --log-level warn \"**/*.svelte\" --ignore-path ../.prettierignore && pnpm exec sort-package-json \"package.json\" \"ui/package.json\" \"ui/electron/package.json\"'",
    "format:check": "bash scripts/system/mise-shim.sh sh -c 'biome format . && pnpm -C ui exec prettier --check --log-level warn \"**/*.svelte\" --ignore-path ../.prettierignore && pnpm exec sort-package-json --check \"package.json\" \"ui/package.json\" \"ui/electron/package.json\"'",
    "gemini:eval": "node scripts/system/gemini-eval.mjs",
    "i18n:verify": "node scripts/system/verify-i18n.mjs",
    "i18n:verify:strict": "node scripts/system/verify-i18n.mjs --strict",
    "icons": "node scripts/native/icons.mjs",
    "icons:test": "node scripts/native/icons/generate-icons.test.mjs",
    "preinstall": "node scripts/system/ensure-pnpm.mjs",
    "postinstall": "node scripts/native/ensure-native-bindings.mjs",
    "legal-date:test": "node scripts/native/legal-date.test.mjs",
    "lib:test": "node scripts/native/_lib.test.mjs",
    "lint": "turbo lint",
    "lint:actionlint": "bash scripts/system/lint-native.sh actionlint",
    "lint:dotenv": "bash scripts/system/lint-native.sh dotenv",
    "lint:fix": "turbo lint:fix",
    "lint:kotlin": "bash scripts/system/lint-native.sh kotlin",
    "lint:native": "bash scripts/system/lint-native.sh",
    "lint:plist": "bash scripts/system/lint-native.sh plist",
    "lint:python": "bash scripts/system/lint-native.sh python",
    "lint:ruby": "bash scripts/system/lint-native.sh ruby",
    "lint:shell": "bash scripts/system/lint-native.sh shell",
    "lint:swift": "bash scripts/system/lint-native.sh swift",
    "lint:toml": "bash scripts/system/lint-native.sh toml",
    "lint:yaml": "bash scripts/system/lint-native.sh yaml",
    "liveness": "node scripts/system/check-liveness.mjs",
    "mascot": "node scripts/native/process-mascot.mjs",
    "mascot:test": "node scripts/native/process-mascot.test.mjs && node scripts/native/brand-mascot.test.mjs",
    "merge": "node scripts/tracker/merge-tracker.mjs",
    "mutation": "pnpm --filter ui exec stryker run",
    "narrative:check": "node scripts/quality/narrative-arc.mjs",
    "native": "node scripts/native/help.mjs",
    "normalize": "node scripts/tracker/normalize-statuses.mjs",
    "og:generate": "node scripts/system/generate-og-cards.mjs",
    "og:generate:force": "node scripts/system/generate-og-cards.mjs --force",
    "outdated": "pnpm outdated -r",
    "particles:build": "node scripts/build-particles.mjs",
    "pdf": "node scripts/cv/generate-pdf.mjs",
    "pr:metadata:test": "node scripts/system/check-pr-metadata.test.mjs",
    "pr:summary:test": "node .github/scripts/sticky/assemble-summary.test.mjs",
    "prepare": "lefthook install || true",
    "profile:seo": "node scripts/quality/profile-seo.mjs",
    "rebuild:native": "node scripts/native/ensure-native-bindings.mjs --force",
    "release": "node scripts/native/release.mjs",
    "reset:data": "node scripts/system/reset-data.mjs",
    "resume:check": "node scripts/quality/resume-quality.mjs",
    "rollback": "node scripts/system/update-system.mjs rollback",
    "scan": "node scripts/scan/scan.mjs",
    "screenshots": "node scripts/system/capture-screenshots.mjs",
    "screenshots:dev": "BASE_URL=http://localhost:5173 node scripts/system/capture-screenshots.mjs",
    "screenshots:diff:test": "node scripts/system/screenshot-diff.test.mjs",
    "screenshots:fast": "node scripts/system/capture-screenshots.mjs --skip-build --skip-seed",
    "screenshots:ios": "node scripts/native/capture-ios-screenshots.mjs",
    "screenshots:seed": "node scripts/system/seed-demo-data.mjs",
    "screenshots:seed:test": "node scripts/system/seed-demo-data.test.mjs",
    "screenshots:serve": "node scripts/system/capture-screenshots.mjs --serve",
    "semantic:match": "node scripts/quality/semantic-match.mjs",
    "setup:native": "node scripts/native/setup.mjs",
    "splash-spec:test": "node scripts/native/splash-spec.test.mjs",
    "symbolicate:test": "node scripts/system/symbolicate.test.mjs",
    "sync-check": "node scripts/quality/cv-sync-check.mjs",
    "test": "bash scripts/system/mise-shim.sh turbo test",
    "test:coverage": "bash scripts/system/mise-shim.sh turbo test:coverage",
    "test:ios": "cd ui/ios/App && bundle exec fastlane test",
    "test:ios:ci": "cd ui/ios/App && bundle exec fastlane test_ci",
    "test:ui": "bash scripts/system/mise-shim.sh turbo test:ui",
    "test:watch": "bash scripts/system/mise-shim.sh turbo test:watch --parallel",
    "typecheck": "bash scripts/system/mise-shim.sh turbo typecheck",
    "update": "node scripts/system/update-system.mjs apply",
    "update:check": "node scripts/system/update-system.mjs check",
    "validate:csp-hashes": "node scripts/system/verify-csp-hashes.mjs",
    "validate:dotenv": "dotenv-linter check --ignore-checks UnorderedKey --skip-updates .env.example .env.act.example",
    "validate:exact-versions": "node scripts/system/validate-exact-versions.mjs",
    "validate:format-sync": "node scripts/system/validate-format-config-sync.mjs",
    "validate:json-schemas": "node scripts/system/validate-json-schemas.mjs",
    "validate:lockfile": "node scripts/system/validate-pnpm-lockfile.mjs",
    "validate:markdown": "markdownlint-cli2",
    "validate:plists": "python3 scripts/system/validate-plists.py",
    "validate:pnpm-scripts": "node scripts/system/verify-pnpm-scripts.mjs",
    "validate:tiny-configs": "node scripts/system/validate-tiny-configs.mjs",
    "validate:version-sync": "node scripts/system/validate-version-sync.mjs",
    "validate:workflows": "node scripts/system/verify-workflow-quality.mjs",
    "validate:xml": "bash scripts/system/validate-xml.sh",
    "verify": "bash scripts/system/mise-shim.sh turbo run check build test:coverage lint format:check verify:no-slop verify:splash-sync verify:contrast verify:comment-style verify:english-only verify:modes verify:merge-markers validate:exact-versions validate:version-sync validate:format-sync validate:json-schemas validate:lockfile validate:pnpm-scripts validate:csp-hashes validate:tiny-configs fonts:verify validate:workflows validate:markdown validate:xml lint:swift lint:kotlin lint:python lint:shell lint:ruby lint:toml lint:yaml lint:dotenv lint:plist lint:actionlint",
    "verify:comment-style": "node scripts/system/verify-comment-style.mjs",
    "verify:comment-style:test": "node scripts/system/verify-comment-style.test.mjs",
    "verify:contrast": "node scripts/system/verify-contrast.mjs",
    "verify:discord-config": "node scripts/system/verify-discord-config.mjs",
    "verify:discord-config:test": "node scripts/system/verify-discord-config.test.mjs",
    "verify:english-only": "node scripts/system/verify-english-only.mjs",
    "verify:english-only:test": "node scripts/system/verify-english-only.test.mjs",
    "verify:merge-markers": "bash scripts/system/verify-merge-markers.sh",
    "verify:modes": "node scripts/system/verify-modes.mjs",
    "verify:modes:test": "node scripts/system/verify-modes.test.mjs",
    "verify:no-personal-identity": "node scripts/system/verify-no-personal-identity.mjs",
    "verify:no-personal-identity:test": "node scripts/system/verify-no-personal-identity.test.mjs",
    "verify:no-slop": "node scripts/system/verify-no-slop.mjs",
    "verify:no-slop:test": "node scripts/system/verify-no-slop.test.mjs",
    "verify:splash-sync": "node scripts/system/verify-splash-sync.mjs",
    "visual:baseline": "node scripts/system/visual-regression.mjs --generate",
    "visual:diff": "node scripts/system/visual-regression.mjs --compare"
  },
  "dependencies": {
    "@google/generative-ai": "catalog:",
    "dotenv": "catalog:",
    "js-yaml": "catalog:",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "ajv": "catalog:",
    "ajv-formats": "catalog:",
    "editorconfig": "catalog:",
    "jsonc-parser": "catalog:",
    "markdownlint-cli2": "catalog:",
    "oxlint": "catalog:",
    "pixelmatch": "catalog:",
    "pngjs": "catalog:",
    "sort-package-json": "catalog:",
    "source-map": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "bun": "please-use-pnpm",
    "node": "26.1.0",
    "npm": "please-use-pnpm",
    "pnpm": "11.1.0",
    "yarn": "please-use-pnpm"
  }
}
